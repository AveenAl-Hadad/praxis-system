    <!-- TEXTBOX -->
    <Style TargetType="TextBox">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="Background" Value="White" />
        <Setter Property="Foreground" Value="{DynamicResource TitleTextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushCustom}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CaretBrush" Value="{DynamicResource TitleTextBrush}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style x:Key="SearchTextBoxStyle" TargetType="TextBox">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="Background" Value="White" />
        <Setter Property="Foreground" Value="{DynamicResource TitleTextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushCustom}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CaretBrush" Value="{DynamicResource TitleTextBrush}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Tag" Value="Suche..." />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Grid>
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2" />
                        </Border>

                        <TextBlock x:Name="PlaceholderText"
                                   Text="{TemplateBinding Tag}"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   IsHitTestVisible="False"
                                   Visibility="Collapsed"/>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                        </Trigger>

                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Text" Value="" />
                                <Condition Property="IsKeyboardFocused" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible" />
                        </MultiTrigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Border" Property="Opacity" Value="0.6" />
                            <Setter TargetName="PlaceholderText" Property="Opacity" Value="0.6" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

