    <Style x:Key="SidebarButtonStyle" TargetType="Button">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Background" Value="{DynamicResource SidebarLightBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SidebarDarkBrush}" />
