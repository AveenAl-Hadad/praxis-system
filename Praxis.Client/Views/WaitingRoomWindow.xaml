<Window x:Class="Praxis.Client.Views.WaitingRoomWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wartezimmer"
        Height="520"
        Width="980"
        WindowStartupLocation="CenterOwner">

    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
            <TextBlock x:Name="InfoTextBlock"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8"
                       Text="Wartezimmer für heute"/>

            <WrapPanel>
                <Button Content="Aktualisieren" Width="110" Height="30" Margin="0,0,10,10" Click="RefreshButton_Click"/>
                <Button Content="Patient da" Width="110" Height="30" Margin="0,0,10,10" Click="CheckInButton_Click"/>
                <Button Content="In Behandlung" Width="110" Height="30" Margin="0,0,10,10" Click="StartTreatmentButton_Click"/>
                <Button Content="Erledigt" Width="110" Height="30" Margin="0,0,10,10" Click="CompleteButton_Click"/>
                <Button Content="Nicht erschienen" Width="130" Height="30" Margin="0,0,10,10" Click="NoShowButton_Click"/>
            </WrapPanel>
        </StackPanel>

        <DataGrid x:Name="WaitingRoomDataGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  SelectionMode="Single">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Status}" Value="Im Wartezimmer">
                            <Setter Property="Background" Value="#FFFFF3CD"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Status}" Value="In Behandlung">
                            <Setter Property="Background" Value="#FFD1ECF1"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Status}" Value="Nicht erschienen">
                            <Setter Property="Background" Value="#FFF8D7DA"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Patient" Binding="{Binding Patient.FullName}" Width="220"/>
                <DataGridTextColumn Header="Termin" Binding="{Binding StartTime, StringFormat=dd.MM.yyyy HH:mm}" Width="150"/>
                <DataGridTextColumn Header="Dauer" Binding="{Binding DurationMinutes}" Width="80"/>
                <DataGridTextColumn Header="Grund" Binding="{Binding Reason}" Width="*"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="140"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>