<Window x:Class="Praxis.Client.Views.WaitingRoomWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wartezimmer"
        Height="620"
        Width="1120"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource CardBorderStyle}"
                Margin="0,0,0,12"
                Background="{StaticResource HeaderPanelBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Wartezimmer"
                               Style="{StaticResource SectionTitleStyle}"/>
                    <TextBlock Text="Anwesende Patienten, Status und Ablauf im Überblick"
                               Foreground="{StaticResource MutedTextBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#EAF6F8"
                        BorderBrush="{StaticResource PrimaryBrush}"
                        BorderThickness="1"
                        CornerRadius="3"
                        Padding="10"
                        HorizontalAlignment="Right">
                    <StackPanel>
                        <TextBlock Text="Statusbereich"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Warteverwaltung"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource CardBorderStyle}"
                Margin="0,0,0,12">
            <WrapPanel>
                <Button Width="130" Height="34" Margin="0,0,8,8"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="AddToWaitingRoom_Click">
                    Hinzufügen
                </Button>

                <Button Width="120" Height="34" Margin="0,0,8,8"
                        Click="MarkArrived_Click">
                    Angekommen
                </Button>

                <Button Width="120" Height="34" Margin="0,0,8,8"
                        Click="CallNext_Click">
                    Nächster
                </Button>

                <Button Width="120" Height="34" Margin="0,0,8,8"
                        Click="CompleteVisit_Click">
                    Abschließen
                </Button>

                <Button Width="130" Height="34"
                        Click="Refresh_Click">
                    Aktualisieren
                </Button>
            </WrapPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource CardBorderStyle}"
                    Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Wartezimmerliste"
                                   FontSize="16"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Patienten mit aktuellem Status und Wartezeit"
                                   FontSize="12"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                    <Border Grid.Row="1"
                            BorderBrush="{StaticResource BorderBrushCustom}"
                            BorderThickness="1"
                            Background="White">
                        <DataGrid x:Name="WaitingRoomDataGrid"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  RowHeaderWidth="0"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Patient" Binding="{Binding PatientName}" Width="*"/>
                                <DataGridTextColumn Header="Ankunft" Binding="{Binding ArrivalTime, StringFormat=HH:mm}" Width="100"/>
                                <DataGridTextColumn Header="Wartezeit" Binding="{Binding WaitingDuration}" Width="120"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="140"/>
                                <DataGridTextColumn Header="Raum" Binding="{Binding Room}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </Border>

            <StackPanel Grid.Column="1">
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Schnellinfo"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="Patient" Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBlock x:Name="SelectedWaitingPatientText"
                                   Text="-"
                                   Margin="0,0,0,8"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="Status" Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBlock x:Name="SelectedWaitingStatusText"
                                   Text="-"
                                   Margin="0,0,0,8"/>

                        <TextBlock Text="Wartezeit" Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBlock x:Name="SelectedWaitingDurationText"
                                   Text="-"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Hinweise"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,10"/>
                        <TextBlock Text="• Statuswerte wie angekommen, wartet, im Zimmer und abgeschlossen sind sinnvoll."
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="• Später kann hier auch Raumzuweisung und Reihenfolge ergänzt werden."
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBlock x:Name="InfoTextBlock"
                                   Text=""
                                   Margin="0,8,0,0"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Window>