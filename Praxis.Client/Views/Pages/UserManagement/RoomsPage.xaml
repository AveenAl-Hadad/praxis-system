<UserControl x:Class="Praxis.Client.Views.Pages.UserManagement.RoomsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Räume verwalten"
                   Style="{StaticResource SectionTitleStyle}" />

        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="42"/>
                    <RowDefinition Height="42"/>
                    <RowDefinition Height="42"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Raumname:" VerticalAlignment="Center"/>
                <TextBox x:Name="NameTextBox"
                         Grid.Column="1"
                         Margin="0,4,12,4"/>

                <TextBlock Grid.Row="1" Text="Beschreibung:" VerticalAlignment="Center"/>
                <TextBox x:Name="BeschreibungTextBox"
                         Grid.Row="1"
                         Grid.Column="1"
                         Margin="0,4,12,4"/>

                <TextBlock Grid.Row="2" Text="Aktiv:" VerticalAlignment="Center"/>
                <CheckBox x:Name="IsActiveCheckBox"
                          Grid.Row="2"
                          Grid.Column="1"
                          VerticalAlignment="Center"
                          IsChecked="True"/>

                <StackPanel Grid.Column="3"
                            Grid.RowSpan="3"
                            Orientation="Vertical"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Button Content="Neu"
                            Width="150"
                            Margin="0,0,8,8"
                            Click="NeuButton_Click"/>
                    <Button Content="Speichern"
                            Width="150"
                            Margin="0,0,8,8"
                            Style="{StaticResource SuccessButtonStyle}"
                            Click="SpeichernButton_Click"/>
                    <Button Content="Löschen"
                            Width="150"
                            Margin="0,0,8,8"
                            Background="#d9534f"
                            Foreground="White"
                            Click="LoeschenButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="4" Style="{StaticResource CardBorderStyle}">
            <DataGrid x:Name="RoomsGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      SelectionChanged="RoomsGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70"/>
                    <DataGridTextColumn Header="Raum" Binding="{Binding Name}" Width="240"/>
                    <DataGridTextColumn Header="Beschreibung" Binding="{Binding Beschreibung}" Width="*"/>
                    <DataGridCheckBoxColumn Header="Aktiv" Binding="{Binding IsActive}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>