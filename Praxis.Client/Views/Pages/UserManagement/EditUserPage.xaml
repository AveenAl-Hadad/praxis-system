<UserControl x:Class="Praxis.Client.Views.Pages.UserManagement.EditUserPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Benutzer bearbeiten"
                       Style="{StaticResource SectionTitleStyle}"/>

            <Border Grid.Row="2"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="320"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Benutzername:"
                               VerticalAlignment="Center"/>
                    <TextBox x:Name="UsernameTextBox"
                             Grid.Column="1"
                             Margin="0,4,0,4"
                             IsReadOnly="True"/>

                    <TextBlock Grid.Row="1"
                               Text="Rolle:"
                               VerticalAlignment="Center"/>
                    <ComboBox x:Name="RoleComboBox"
                              Grid.Row="1"
                              Grid.Column="1"
                              Margin="0,4,0,4"/>

                    <TextBlock Grid.Row="2"
                               Text="Aktiv:"
                               VerticalAlignment="Center"/>
                    <CheckBox x:Name="IsActiveCheckBox"
                              Grid.Row="2"
                              Grid.Column="1"
                              VerticalAlignment="Center"/>

                    <TextBlock Grid.Row="3"
                               Text="Neues Passwort:"
                               VerticalAlignment="Center"/>
                    <PasswordBox x:Name="NewPasswordBox"
                                 Grid.Row="3"
                                 Grid.Column="1"
                                 Margin="0,4,0,4"/>

                    <TextBlock Grid.Row="4"
                               Text="Passwort bestätigen:"
                               VerticalAlignment="Center"/>
                    <PasswordBox x:Name="ConfirmPasswordBox"
                                 Grid.Row="4"
                                 Grid.Column="1"
                                 Margin="0,4,0,4"/>

                    <TextBlock Grid.Column="3"
                               Text="Hinweis:"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="4"
                               Text="Benutzername ist fix und wird nicht geändert."
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource MutedTextBrush}"/>

                    <TextBlock Grid.Row="1"
                               Grid.Column="3"
                               Text="Rolle:"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="1"
                               Grid.Column="4"
                               Text="Administrator, Mitarbeiter oder Arzt"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource MutedTextBrush}"/>

                    <TextBlock Grid.Row="3"
                               Grid.Column="3"
                               Text="Passwort:"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="3"
                               Grid.Column="4"
                               Text="Leer lassen, wenn Passwort unverändert bleiben soll."
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource MutedTextBrush}"/>
                </Grid>
            </Border>

            <StackPanel Grid.Row="4"
                        Orientation="Horizontal"
                        HorizontalAlignment="Left">
                <Button Content="Speichern"
                        Width="130"
                        Style="{StaticResource SuccessButtonStyle}"
                        Click="SaveButton_Click"/>

                <Button Content="Zurück"
                        Width="130"
                        Margin="10,0,0,0"
                        Click="BackButton_Click"/>

                <Button Content="Löschen"
                        Width="130"
                        Margin="10,0,0,0"
                        Background="#d9534f"
                        Foreground="White"
                        Click="DeleteButton_Click"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>