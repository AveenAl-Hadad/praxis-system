<UserControl x:Class="Praxis.Client.Views.Pages.UserManagement.UserManagementPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Benutzerverwaltung"
                   Style="{StaticResource SectionTitleStyle}"
                   Margin="0,0,0,10"/>

        <Border Grid.Row="1"
                Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="SearchUserTextBox"
                         Grid.Column="0"
                         Height="34"
                         Style="{StaticResource SearchTextBoxStyle}"
                         Tag="Benutzer suchen..."
                         TextChanged="SearchUserTextBox_TextChanged"/>

                <Button Grid.Column="1"
                        Content="Neu"
                        Margin="10,0,0,0"
                        Style="{StaticResource SuccessButtonStyle}"
                        Click="NewUserButton_Click"/>

                <Button Grid.Column="2"
                        Content="Bearbeiten"
                        Margin="10,0,0,0"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="ChangeRoleButton_Click"/>

                <Button Grid.Column="3"
                        Content="Passwort"
                        Margin="10,0,0,0"
                        Style="{StaticResource WarningButtonStyle}"
                        Click="ResetPasswordButton_Click"/>

                <Button Grid.Column="4"
                        Content="Aktiv/Inaktiv"
                        Margin="10,0,0,0"
                        Click="ToggleUserButton_Click"/>

                <Button Grid.Column="5"
                        Content="Löschen"
                        Margin="10,0,0,0"
                        Background="#d9534f"
                        Foreground="White"
                        Click="DeleteUserButton_Click"/>
                <TextBlock Grid.Column="6"
                           Margin="16,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource MutedTextBrush}"
                           Text="Nur für Administratoren sichtbar"/>
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Style="{StaticResource CardBorderStyle}">
            <DataGrid x:Name="UsersGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70"/>
                    <DataGridTextColumn Header="Benutzername" Binding="{Binding Username}" Width="180"/>
                    <DataGridTextColumn Header="Rolle" Binding="{Binding Role}" Width="140"/>
                    <DataGridCheckBoxColumn Header="Aktiv" Binding="{Binding IsActive}" Width="80"/>
                    <DataGridTextColumn Header="Erstellt am" Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy HH:mm}" Width="170"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
