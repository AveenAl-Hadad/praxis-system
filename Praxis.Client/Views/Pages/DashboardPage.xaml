<UserControl x:Class="Praxis.Client.Views.Pages.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Kopf -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Dashboard"
                               Style="{StaticResource SectionTitleStyle}"/>
                    <TextBlock Text="Tagesübersicht der Praxis"
                               Margin="0,4,0,0"
                               Foreground="{DynamicResource MutedTextBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="Aktualisieren"
                            Width="120"
                            Margin="0,0,10,0"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="RefreshButton_Click"/>

                    <Button Content="Patientensuche"
                            Width="140"
                            Click="OpenPatientsButton_Click"/>
                </StackPanel>
            </Grid>

            <!-- Gesamtzahlen -->
            <UniformGrid Grid.Row="2"
                         Columns="4"
                         Margin="0">
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="Patienten gesamt"
                                   Foreground="{DynamicResource MutedTextBrush}"/>
                        <TextBlock x:Name="TotalPatientsText"
                                   Text="0"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="Termine gesamt"
                                   Foreground="{DynamicResource MutedTextBrush}"/>
                        <TextBlock x:Name="TotalAppointmentsText"
                                   Text="0"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="Rechnungen gesamt"
                                   Foreground="{DynamicResource MutedTextBrush}"/>
                        <TextBlock x:Name="TotalInvoicesText"
                                   Text="0"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Rezepte gesamt"
                                   Foreground="{DynamicResource MutedTextBrush}"/>
                        <TextBlock x:Name="TotalPrescriptionsText"
                                   Text="0"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Monats- und Tagesübersicht -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Monatswerte -->
                <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Aktueller Monat"
                                   FontWeight="Bold"
                                   FontSize="15"/>
                        <TextBlock Text="Leistungs- und Umsatzübersicht"
                                   Margin="0,2,0,12"
                                   Foreground="{DynamicResource MutedTextBrush}"/>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="180"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Termine im Monat" Grid.Row="0" Grid.Column="0" Margin="0,0,0,8"/>
                            <TextBlock x:Name="MonthAppointmentsText" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" FontWeight="SemiBold"/>

                            <TextBlock Text="Rechnungen im Monat" Grid.Row="1" Grid.Column="0" Margin="0,0,0,8"/>
                            <TextBlock x:Name="MonthInvoicesText" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" FontWeight="SemiBold"/>

                            <TextBlock Text="Umsatz im Monat" Grid.Row="2" Grid.Column="0" Margin="0,0,0,8"/>
                            <TextBlock x:Name="MonthRevenueText" Grid.Row="2" Grid.Column="1" Margin="0,0,0,8" FontWeight="SemiBold"/>

                            <TextBlock Text="Gesamtumsatz" Grid.Row="3" Grid.Column="0"/>
                            <TextBlock x:Name="TotalRevenueText" Grid.Row="3" Grid.Column="1" FontWeight="SemiBold"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Heute -->
                <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Heute"
                                   FontWeight="Bold"
                                   FontSize="15"/>
                        <TextBlock Text="Status der heutigen Termine"
                                   Margin="0,2,0,12"
                                   Foreground="{DynamicResource MutedTextBrush}"/>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="90"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Heutige Termine" Grid.Row="0" Grid.Column="0" Margin="0,0,0,8"/>
                            <TextBlock x:Name="TodayAppointmentsText" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" FontWeight="SemiBold"/>

                            <TextBlock Text="Geplant" Grid.Row="1" Grid.Column="0" Margin="0,0,0,8"/>
                            <TextBlock x:Name="PlannedAppointmentsText" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" FontWeight="SemiBold"/>

                            <TextBlock Text="Erledigt" Grid.Row="2" Grid.Column="0" Margin="0,0,0,8"/>
                            <TextBlock x:Name="CompletedAppointmentsText" Grid.Row="2" Grid.Column="1" Margin="0,0,0,8" FontWeight="SemiBold"/>

                            <TextBlock Text="Abgesagt" Grid.Row="3" Grid.Column="0"/>
                            <TextBlock x:Name="CancelledAppointmentsText" Grid.Row="3" Grid.Column="1" FontWeight="SemiBold"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Aufgaben + Hinweise -->
            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Aufgaben -->
                <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="Aufgaben &amp; Wiedervorlagen"
                                       FontWeight="Bold"
                                       FontSize="15"/>
                            <TextBlock Text="Offene und fällige Aufgaben"
                                       Margin="0,2,0,0"
                                       Foreground="{DynamicResource MutedTextBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Orientation="Horizontal">
                            <Button Content="Neue Aufgabe"
                                    Width="130"
                                    Margin="0,0,10,0"
                                    Click="AddTaskButton_Click"/>

                            <Button Content="Erledigen"
                                    Width="110"
                                    Click="CompleteTaskButton_Click"/>
                        </StackPanel>

                        <UniformGrid Grid.Row="4" Columns="3">
                            <StackPanel>
                                <TextBlock Text="Offen"
                                           Foreground="{DynamicResource MutedTextBrush}"/>
                                <TextBlock x:Name="OpenTasksText"
                                           Text="0"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Margin="0,6,0,0"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Heute fällig"
                                           Foreground="{DynamicResource MutedTextBrush}"/>
                                <TextBlock x:Name="DueTodayTasksText"
                                           Text="0"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Margin="0,6,0,0"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Überfällig"
                                           Foreground="{DynamicResource MutedTextBrush}"/>
                                <TextBlock x:Name="OverdueTasksText"
                                           Text="0"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Margin="0,6,0,0"/>
                            </StackPanel>
                        </UniformGrid>

                        <DataGrid Grid.Row="6"
                                  x:Name="TasksGrid"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  MouseDoubleClick="TasksGrid_MouseDoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Titel" Binding="{Binding Title}" Width="180"/>
                                <DataGridTextColumn Header="Patient" Binding="{Binding PatientName}" Width="180"/>
                                <DataGridTemplateColumn Header="Priorität" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding PriorityColor}"
                                                    CornerRadius="10"
                                                    Padding="8,3"
                                                    HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding Priority}"
                                                           Foreground="White"
                                                           FontWeight="SemiBold"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="Fällig" Binding="{Binding DueDate}" Width="120"/>

                                <DataGridTemplateColumn Header="Status" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding StatusColor}"
                                                    CornerRadius="10"
                                                    Padding="8,3"
                                                    HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding Status}"
                                                           Foreground="White"
                                                           FontWeight="SemiBold"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Zuständig" Binding="{Binding AssignedTo}" Width="140"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- Hinweise -->
                <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="Praxis-Hinweise"
                                       FontWeight="Bold"
                                       FontSize="15"/>
                            <TextBlock Text="Wichtige Informationen für den Tag"
                                       Margin="0,2,0,0"
                                       Foreground="{DynamicResource MutedTextBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2"
                                    Orientation="Horizontal">
                            <Button Content="Neuer Hinweis"
                                    Width="130"
                                    Margin="0,0,10,0"
                                    Click="AddNoticeButton_Click"/>

                            <Button Content="Deaktivieren"
                                    Width="120"
                                    Click="DeactivateNoticeButton_Click"/>
                        </StackPanel>

                        <UniformGrid Grid.Row="4" Columns="2">
                            <StackPanel>
                                <TextBlock Text="Aktive Hinweise"
                                           Foreground="{DynamicResource MutedTextBrush}"/>
                                <TextBlock x:Name="ActiveNoticesText"
                                           Text="0"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Margin="0,6,0,0"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Angeheftet"
                                           Foreground="{DynamicResource MutedTextBrush}"/>
                                <TextBlock x:Name="PinnedNoticesText"
                                           Text="0"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Margin="0,6,0,0"/>
                            </StackPanel>
                        </UniformGrid>

                        <DataGrid Grid.Row="6"
                                  x:Name="NoticesGrid"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  MouseDoubleClick="NoticesGrid_MouseDoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Titel" Binding="{Binding Title}" Width="170"/>
                                <DataGridTemplateColumn Header="Kategorie" Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding CategoryColor}"
                                                    CornerRadius="10"
                                                    Padding="8,3"
                                                    HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding Category}"
                                                           Foreground="White"
                                                           FontWeight="SemiBold"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Hinweis" Binding="{Binding Content}" Width="280"/>
                                <DataGridTextColumn Header="Bis" Binding="{Binding VisibleUntil}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>

            <!-- Heutige Termine -->
            <Border Grid.Row="8" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Heutige Termine"
                                   FontWeight="Bold"
                                   FontSize="15"/>
                        <TextBlock x:Name="TodayDateText"
                                   Margin="0,2,0,0"
                                   Foreground="{DynamicResource MutedTextBrush}"/>
                    </StackPanel>

                    <DataGrid Grid.Row="2"
                              x:Name="TodayAppointmentsGrid"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Uhrzeit" Binding="{Binding Time}" Width="110"/>
                            <DataGridTextColumn Header="Patient" Binding="{Binding PatientName}" Width="220"/>
                            <DataGridTextColumn Header="Grund" Binding="{Binding Reason}" Width="260"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="140"/>
                            <DataGridTextColumn Header="Dauer (Min.)" Binding="{Binding DurationMinutes}" Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>