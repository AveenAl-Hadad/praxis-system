<UserControl x:Class="Praxis.Client.Views.Pages.Labor.LaborPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Titel -->
        <TextBlock Grid.Row="0"
                   Text="Labordaten importieren"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="#1F2937"/>

        <!-- Oberer Bereich -->
        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#D1D5DB"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Links -->
                <StackPanel>
                    <TextBlock Text="LDT-Dateien und Vorschau"
                               FontWeight="Bold"
                               FontSize="15"
                               Foreground="#111827"/>

                    <TextBlock Text="Dateien zuerst laden und prüfen. Erst mit 'Import speichern' werden sie in die Datenbank übernommen."
                               Margin="0,6,0,14"
                               Foreground="#6B7280"
                               TextWrapping="Wrap"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="130"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="DirectoryTextBox"
                                 Height="34"
                                 VerticalContentAlignment="Center"
                                 Margin="0,0,10,0"/>

                        <Button Grid.Column="1"
                                x:Name="BrowseButton"
                                Content="Durchsuchen"
                                Height="34"
                                Click="BrowseButton_Click"
                                Background="#E5E7EB"/>
                    </Grid>

                    <WrapPanel Margin="0,14,0,0">
                        <Button x:Name="PreviewButton"
                                Content="Vorschau laden"
                                Width="140"
                                Height="36"
                                Margin="0,0,10,10"
                                Click="PreviewButton_Click"
                                Background="#06B6D4"
                                Foreground="White"
                                FontWeight="SemiBold"/>

                        <Button x:Name="SaveImportButton"
                                Content="Import speichern"
                                Width="150"
                                Height="36"
                                Margin="0,0,10,10"
                                Click="SaveImportButton_Click"
                                Background="#16A34A"
                                Foreground="White"
                                FontWeight="SemiBold"/>

                        <Button x:Name="RefreshStoredButton"
                                Content="Gespeicherte laden"
                                Width="160"
                                Height="36"
                                Margin="0,0,10,10"
                                Click="RefreshStoredButton_Click"
                                Background="#E5E7EB"/>

                        <Button x:Name="ClearDirectoryButton"
                                Content="Zurücksetzen"
                                Width="130"
                                Height="36"
                                Margin="0,0,10,10"
                                Click="ClearDirectoryButton_Click"
                                Background="#E5E7EB"/>
                    </WrapPanel>
                </StackPanel>

                <!-- Rechts -->
                <Border Grid.Column="2"
                        Background="#F9FAFB"
                        BorderBrush="#D1D5DB"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12">
                    <StackPanel>
                        <TextBlock Text="Status"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   Foreground="#111827"/>

                        <TextBlock x:Name="WaitingCountTextBlock"
                                   Text="0 Dateien in Vorschau"
                                   Margin="0,12,0,4"
                                   FontSize="13"/>

                        <TextBlock x:Name="ErrorCountTextBlock"
                                   Text="0 Dateien mit Fehler"
                                   Margin="0,0,0,4"
                                   FontSize="13"/>

                        <TextBlock x:Name="LastCheckTextBlock"
                                   Text="Noch keine Aktion"
                                   Margin="0,0,0,12"
                                   Foreground="#6B7280"
                                   FontSize="12"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Tabelle -->
        <Border Grid.Row="4"
                Background="White"
                BorderBrush="#D1D5DB"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10">
            <DataGrid x:Name="LaborGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      RowHeight="34">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Dateiname" Binding="{Binding Datei}" Width="220"/>
                    <DataGridTextColumn Header="Labor" Binding="{Binding Labor}" Width="180"/>
                    <DataGridTextColumn Header="Erstellt" Binding="{Binding Erstellt}" Width="170"/>
                    <DataGridTextColumn Header="Betriebsstätte" Binding="{Binding Betriebsstaette}" Width="180"/>
                    <DataGridTextColumn Header="BSNR/BSID" Binding="{Binding Bsnr}" Width="120"/>
                    <DataGridTextColumn Header="Kundennummer" Binding="{Binding Kundennummer}" Width="140"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="180"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>