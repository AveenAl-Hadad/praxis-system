<UserControl x:Class="Praxis.Client.Views.Pages.Labor.LaborPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Titel -->
        <TextBlock Text="Labordaten importieren"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="#1F2937"/>

        <!-- Oberer Bereich -->
        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#D1D5DB"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Links -->
                <StackPanel>
                    <TextBlock Text="LDT-Dateien und Import"
                               FontWeight="Bold"
                               FontSize="15"
                               Foreground="#111827"/>

                    <TextBlock Text="Dateien aus Verzeichnis lesen, prüfen und in die Übersicht übernehmen."
                               Margin="0,6,0,14"
                               Foreground="#6B7280"
                               TextWrapping="Wrap"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="180"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="DirectoryTextBox"
                                 Height="34"
                                 VerticalContentAlignment="Center"
                                 Text="C:\Import\Labor"/>

                        <Button Grid.Column="1"
                                Content="Durchsuchen"
                                Margin="10,0,0,0"
                                Height="34"
                                Background="#E5E7EB"/>

                        <Button Grid.Column="2"
                                Content="KV-Connect prüfen"
                                Margin="10,0,0,0"
                                Height="34"
                                Background="#F59E0B"
                                Foreground="White"
                                FontWeight="SemiBold"/>
                    </Grid>

                    <WrapPanel Margin="0,14,0,0">
                        <Button Content="Einlesen"
                                Width="120"
                                Height="36"
                                Margin="0,0,10,10"
                                Background="#06B6D4"
                                Foreground="White"
                                FontWeight="SemiBold"/>

                        <Button Content="Inhalt anzeigen"
                                Width="130"
                                Height="36"
                                Margin="0,0,10,10"
                                Background="#E5E7EB"/>

                        <Button Content="Aus Verzeichnis löschen"
                                Width="170"
                                Height="36"
                                Margin="0,0,10,10"
                                Background="#E5E7EB"/>

                        <CheckBox Content="Prüfmodul verwenden"
                                  VerticalAlignment="Center"
                                  Margin="0,8,0,0"/>
                    </WrapPanel>
                </StackPanel>

                <!-- Rechts -->
                <Border Grid.Column="2"
                        Background="#F9FAFB"
                        BorderBrush="#D1D5DB"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12">
                    <StackPanel>
                        <TextBlock Text="Importstatus"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   Foreground="#111827"/>

                        <TextBlock Text="0 Dateien wartend"
                                   Margin="0,12,0,4"
                                   FontSize="13"/>

                        <TextBlock Text="0 Dateien mit Fehler"
                                   Margin="0,0,0,4"
                                   FontSize="13"/>

                        <TextBlock Text="Letzte Prüfung: heute"
                                   Margin="0,0,0,12"
                                   Foreground="#6B7280"
                                   FontSize="12"/>

                        <Button Content="Laborbücher zuordnen"
                                Height="34"
                                Background="#06B6D4"
                                Foreground="White"
                                FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Tabelle -->
        <Border Grid.Row="4"
                Background="White"
                BorderBrush="#D1D5DB"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10">
            <DataGrid x:Name="LaborGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      RowHeight="34">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Dateiname" Binding="{Binding Datei}" Width="220"/>
                    <DataGridTextColumn Header="Labor" Binding="{Binding Labor}" Width="220"/>
                    <DataGridTextColumn Header="Erstellungsdatum" Binding="{Binding Erstellt}" Width="170"/>
                    <DataGridTextColumn Header="Betriebsstätte" Binding="{Binding Betriebsstaette}" Width="200"/>
                    <DataGridTextColumn Header="BSNR/BSID" Binding="{Binding Bsnr}" Width="140"/>
                    <DataGridTextColumn Header="Kundennummer" Binding="{Binding Kundennummer}" Width="140"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>