<UserControl x:Class="Praxis.Client.Views.Pages.Patienten.WaitingRoomPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Wartezimmer"
                   Style="{StaticResource SectionTitleStyle}"/>

        <Border Grid.Row="2"
                Style="{StaticResource CardBorderStyle}">
            <StackPanel Orientation="Horizontal">
                <Button Content="Aktualisieren"
                        Width="120"
                        Margin="0,0,10,0"
                        Click="RefreshButton_Click"/>

                <Button Content="Anmelden"
                        Width="120"
                        Margin="0,0,10,0"
                        Style="{StaticResource SuccessButtonStyle}"
                        Click="CheckInButton_Click"/>

                <Button Content="In Raum 1"
                        Width="120"
                        Margin="0,0,10,0"
                        Click="MoveRoom1Button_Click"/>

                <Button Content="In Raum 2"
                        Width="120"
                        Margin="0,0,10,0"
                        Click="MoveRoom2Button_Click"/>

                <Button Content="Erledigt"
                        Width="120"
                        Margin="0,0,10,0"
                        Click="CompleteButton_Click"/>

                <Button Content="Absagen"
                        Width="120"
                        Click="CancelButton_Click"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="4"
                Style="{StaticResource CardBorderStyle}">
            <DataGrid x:Name="WaitingRoomGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70"/>
                    <DataGridTextColumn Header="Patient" Binding="{Binding Patient.FullName}" Width="220"/>
                    <DataGridTextColumn Header="Beginn" Binding="{Binding StartTime, StringFormat=dd.MM.yyyy HH:mm}" Width="170"/>
                    <DataGridTextColumn Header="Grund" Binding="{Binding Reason}" Width="220"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="130"/>
                    <DataGridTextColumn Header="Behandlungsstatus" Binding="{Binding TreatmentState}" Width="160"/>
                    <DataGridTextColumn Header="Raum" Binding="{Binding RoomName}" Width="120"/>
                    <DataGridTextColumn Header="Check-in" Binding="{Binding CheckedInAt, StringFormat=dd.MM.yyyy HH:mm}" Width="170"/>
                    <DataGridTextColumn Header="Notiz" Binding="{Binding InternalNote}" Width="220"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>