<UserControl x:Class="Praxis.Client.Views.Pages.Patienten.PatientDocumentsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Patientendokumente"
                   Style="{StaticResource SectionTitleStyle}"/>

        <Border Grid.Row="2"
                Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="320"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="40"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Patient:" VerticalAlignment="Center"/>
                <TextBox x:Name="PatientNameTextBox"
                         Grid.Column="1"
                         Margin="0,4,0,4"
                         IsReadOnly="True"/>

                <TextBlock Grid.Row="1" Text="Geburtsdatum:" VerticalAlignment="Center"/>
                <TextBox x:Name="GeburtsdatumTextBox"
                         Grid.Row="1"
                         Grid.Column="1"
                         Margin="0,4,0,4"
                         IsReadOnly="True"/>

                <TextBlock Grid.Row="2" Text="Telefon:" VerticalAlignment="Center"/>
                <TextBox x:Name="TelefonTextBox"
                         Grid.Row="2"
                         Grid.Column="1"
                         Margin="0,4,0,4"
                         IsReadOnly="True"/>

                <TextBlock Grid.Column="3" Text="E-Mail:" VerticalAlignment="Center"/>
                <TextBox x:Name="EmailTextBox"
                         Grid.Column="4"
                         Margin="0,4,0,4"
                         IsReadOnly="True"/>

                <TextBlock Grid.Row="1"
                           Grid.Column="3"
                           Text="Hinweis:"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Row="1"
                           Grid.Column="4"
                           Text="Hier wird später die echte Dokumentenliste eingebunden."
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource MutedTextBrush}"/>
            </Grid>
        </Border>

        <Border Grid.Row="4"
                Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Button Content="Neues Dokument"
                            Style="{StaticResource SuccessButtonStyle}"
                            Click="AddDocumentButton_Click"/>

                    <Button Content="Zurück zur Suche"
                            Margin="10,0,0,0"
                            Click="BackButton_Click"/>
                </StackPanel>

                <DataGrid Grid.Row="2"
                          x:Name="DocumentsGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70"/>
                        <DataGridTextColumn Header="Titel" Binding="{Binding Title}" Width="220"/>
                        <DataGridTextColumn Header="Typ" Binding="{Binding DocumentType}" Width="160"/>
                        <DataGridTextColumn Header="Erstellt am" Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy HH:mm}" Width="180"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>