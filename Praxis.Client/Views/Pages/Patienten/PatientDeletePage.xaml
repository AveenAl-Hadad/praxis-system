<UserControl x:Class="Praxis.Client.Views.Pages.Patienten.PatientDeletePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Patient löschen"
                       Style="{StaticResource SectionTitleStyle}"/>

            <Border Grid.Row="2"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="360"/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="320"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Patient auswählen:" VerticalAlignment="Center"/>
                    <ComboBox x:Name="PatientComboBox"
                              Grid.Column="1"
                              Margin="0,4,0,4"
                              DisplayMemberPath="FullName"
                              SelectionChanged="PatientComboBox_SelectionChanged"/>

                    <TextBlock Grid.Row="1" Text="Vorname:" VerticalAlignment="Center"/>
                    <TextBox x:Name="VornameTextBox"
                             Grid.Row="1"
                             Grid.Column="1"
                             Margin="0,4,0,4"
                             IsReadOnly="True"/>

                    <TextBlock Grid.Row="2" Text="Nachname:" VerticalAlignment="Center"/>
                    <TextBox x:Name="NachnameTextBox"
                             Grid.Row="2"
                             Grid.Column="1"
                             Margin="0,4,0,4"
                             IsReadOnly="True"/>

                    <TextBlock Grid.Row="3" Text="Geburtsdatum:" VerticalAlignment="Center"/>
                    <DatePicker x:Name="GeburtsdatumPicker"
                                Grid.Row="3"
                                Grid.Column="1"
                                Margin="0,4,0,4"
                                IsEnabled="False"/>

                    <TextBlock Grid.Row="4" Text="Telefon:" VerticalAlignment="Center"/>
                    <TextBox x:Name="TelefonTextBox"
                             Grid.Row="4"
                             Grid.Column="1"
                             Margin="0,4,0,4"
                             IsReadOnly="True"/>

                    <TextBlock Grid.Column="3" Text="E-Mail:" VerticalAlignment="Center"/>
                    <TextBox x:Name="EmailTextBox"
                             Grid.Column="4"
                             Margin="0,4,0,4"
                             IsReadOnly="True"/>

                    <TextBlock Grid.Row="1" Grid.Column="3" Text="Adresse:" VerticalAlignment="Center"/>
                    <TextBox x:Name="AdresseTextBox"
                             Grid.Row="1"
                             Grid.Column="4"
                             Margin="0,4,0,4"
                             IsReadOnly="True"/>

                    <TextBlock Grid.Row="2" Grid.Column="3" Text="PLZ / Ort:" VerticalAlignment="Center"/>
                    <TextBox x:Name="OrtTextBox"
                             Grid.Row="2"
                             Grid.Column="4"
                             Margin="0,4,0,4"
                             IsReadOnly="True"/>

                    <TextBlock Grid.Row="3" Grid.Column="3" Text="Warnung:" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="3"
                               Grid.Column="4"
                               Text="Das Löschen entfernt den Patienten dauerhaft aus der Datenbank."
                               TextWrapping="Wrap"
                               Foreground="#C0392B"
                               VerticalAlignment="Center"/>

                    <TextBlock Grid.Row="4" Grid.Column="3" Text="Hinweis:" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="4"
                               Grid.Column="4"
                               Text="Bitte vorher prüfen, ob der richtige Patient ausgewählt ist."
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource MutedTextBrush}"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <StackPanel Grid.Row="4"
                        Orientation="Horizontal"
                        HorizontalAlignment="Left">
                <Button Content="Patient löschen"
                        Width="150"
                        Background="#d9534f"
                        Foreground="White"
                        Click="DeleteButton_Click"/>

                <Button Content="Zurück"
                        Width="130"
                        Margin="10,0,0,0"
                        Click="BackButton_Click"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>