<UserControl x:Class="Praxis.Client.Views.Pages.Patienten.PatientAppointmentsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"             
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
              HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>                <!-- Titel -->
                <RowDefinition Height="16"/>

                <RowDefinition Height="Auto"/>                <!-- Patientendaten -->
                <RowDefinition Height="16"/>

                <RowDefinition Height="Auto"/>                <!-- Terminformular -->
                <RowDefinition Height="16"/>

                <RowDefinition Height="220"/>                <!-- Freie Slots -->
                <RowDefinition Height="16"/>

                <RowDefinition Height="400"/>                <!-- Kalender -->
                <RowDefinition Height="16"/>

                <RowDefinition Height="320"/>                <!-- Patientenfluss -->
                <RowDefinition Height="16"/>

                <RowDefinition Height="*"/>                <!-- Terminliste -->
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Patiententermine"
                       Style="{StaticResource SectionTitleStyle}"/>

            <!-- Patientendaten -->
            <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="320"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Patient:" VerticalAlignment="Center"/>
                    <TextBox x:Name="PatientNameTextBox"
                             Grid.Column="1"
                             Margin="0,4,0,4"
                             IsReadOnly="True"/>

                    <TextBlock Grid.Row="1"
                               Text="Geburtsdatum:"
                               VerticalAlignment="Center"/>
                    <TextBox x:Name="GeburtsdatumTextBox"
                             Grid.Row="1"
                             Grid.Column="1"
                             Margin="0,4,0,4"
                             IsReadOnly="True"/>

                    <TextBlock Grid.Row="2"
                               Text="Telefon:"
                               VerticalAlignment="Center"/>
                    <TextBox x:Name="TelefonTextBox"
                             Grid.Row="2"
                             Grid.Column="1"
                             Margin="0,4,0,4"
                             IsReadOnly="True"/>

                    <TextBlock Grid.Column="3"
                               Text="E-Mail:"
                               VerticalAlignment="Center"/>
                    <TextBox x:Name="EmailTextBox"
                             Grid.Column="4"
                             Margin="0,4,0,4"
                             IsReadOnly="True"/>

                    <TextBlock Grid.Row="1"
                               Grid.Column="3"
                               Text="Hinweis:"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="1"
                               Grid.Column="4"
                               Text="Datum, Dauer und Raum wählen – freie Slots werden automatisch berechnet."
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource MutedTextBrush}"/>
                </Grid>
            </Border>
          
            <!-- Terminformular -->
            <Border Grid.Row="4"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="260"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="42"/>
                        <RowDefinition Height="42"/>
                        <RowDefinition Height="42"/>
                        <RowDefinition Height="42"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Datum:" VerticalAlignment="Center"/>
                    <DatePicker x:Name="AppointmentDatePicker"
                                Grid.Column="1"
                                Margin="0,4,0,4"
                                SelectedDateChanged="AppointmentCriteria_Changed"/>

                    <TextBlock Grid.Column="3"
                               Text="Uhrzeit (HH:mm):"
                               VerticalAlignment="Center"/>
                    <TextBox x:Name="AppointmentTimeTextBox"
                             Grid.Column="4"
                             Margin="0,4,0,4"
                             Text="09:00"/>

                    <TextBlock Grid.Row="1"
                               Text="Dauer (Minuten):"
                               VerticalAlignment="Center"/>
                    <TextBox x:Name="DurationTextBox"
                             Grid.Row="1"
                             Grid.Column="1"
                             Margin="0,4,0,4"
                             Text="30"
                             TextChanged="AppointmentCriteria_Changed"/>

                    <TextBlock Grid.Row="1"
                               Grid.Column="3"
                               Text="Raum:"
                               VerticalAlignment="Center"/>
                    <ComboBox x:Name="RoomComboBox"
                              Grid.Row="1"
                              Grid.Column="4"
                              Margin="0,4,0,4"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Name"
                              SelectionChanged="AppointmentCriteria_Changed"/>

                    <TextBlock Grid.Row="2"
                               Text="Grund:"
                               VerticalAlignment="Center"/>
                    <TextBox x:Name="ReasonTextBox"
                             Grid.Row="2"
                             Grid.Column="1"
                             Margin="0,4,0,4"/>

                    <TextBlock Grid.Row="2"
                               Grid.Column="3"
                               Text="Status:"
                               VerticalAlignment="Center"/>
                    <ComboBox x:Name="StatusComboBox"
                              Grid.Row="2"
                              Grid.Column="4"
                              Margin="0,4,0,4">
                        <ComboBoxItem Content="Geplant" IsSelected="True"/>
                        <ComboBoxItem Content="Bestätigt"/>
                        <ComboBoxItem Content="Verschoben"/>
                        <ComboBoxItem Content="Abgesagt"/>
                    </ComboBox>

                    <StackPanel Grid.Row="3"
                                Grid.ColumnSpan="5"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Content="Freie Slots aktualisieren"
                                Width="150"
                                Margin="0,0,8,0"
                                Click="RefreshSlotsButton_Click"/>

                        <Button Content="Neu"
                                Width="90"
                                Margin="0,0,8,0"
                                Click="NewAppointmentButton_Click"/>

                        <Button Content="Speichern"
                                Width="100"
                                Margin="0,0,8,0"
                                Style="{StaticResource SuccessButtonStyle}"
                                Click="SaveAppointmentButton_Click"/>

                        <Button Content="Löschen"
                                Width="90"
                                Margin="0,0,8,0"
                                Click="DeleteAppointmentButton_Click"/>

                        <Button Content="Zurück zur Suche"
                                Width="140"
                                Click="BackButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Freie Slots -->
            <Border Grid.Row="6"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Freie Zeitfenster"
                               FontSize="18"
                               FontWeight="SemiBold"/>

                    <ListBox Grid.Row="2"
                             x:Name="AvailableSlotsListBox"
                             SelectionChanged="AvailableSlotsListBox_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10"
                                        Margin="0,0,0,6"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <TextBlock Text="{Binding SlotLabel}"/>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Kalender Block -->
            <Border Grid.Row="8"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>    <!-- Kopfzeile -->
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>   <!-- Kennzahlen -->
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>   <!-- Filterleiste -->
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>     <!-- Legende -->
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>      <!-- Kalender-ScrollViewer -->
                    </Grid.RowDefinitions>
                    <!-- Kopfzeile -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Kalender-Raumplaner"
                                       FontSize="18"
                                       FontWeight="SemiBold"/>

                            <TextBlock Text="  (15-Minuten-Raster)"
                                       Margin="8,2,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource MutedTextBrush}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button Content="&lt;"
                                    Width="36"
                                    Margin="0,0,8,0"
                                    Click="PreviousDayButton_Click"/>

                            <Button Content="Heute"
                                    Width="70"
                                    Margin="0,0,8,0"
                                    Click="TodayButton_Click"/>

                            <Button Content="&gt;"
                                    Width="36"
                                    Margin="0,0,8,0"
                                    Click="NextDayButton_Click"/>

                            <ToggleButton x:Name="WeekModeToggleButton"
                                          Width="110"
                                          Content="Wochenmodus"
                                          Checked="WeekModeToggleButton_Checked"
                                          Unchecked="WeekModeToggleButton_Unchecked"/>
                        </StackPanel>
                    </Grid>
                    <!-- Kennzahlen  -->
                    <UniformGrid Grid.Row="2" Columns="6" Margin="0,0,0,0">
                        <Border Margin="0,0,8,0"
                                Padding="10"
                                BorderThickness="1"
                                CornerRadius="8">
                            <StackPanel>
                                <TextBlock Text="Sichtbar gesamt" FontWeight="SemiBold"/>
                                <TextBlock x:Name="PlannerVisibleCountTextBlock"
                                           Text="0"
                                           FontSize="22"
                                           FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <Border Margin="0,0,8,0"
                                Padding="10"
                                BorderThickness="1"
                                CornerRadius="8"
                                 Background="LightGreen"
                                 BorderBrush="SeaGreen" >
                            <StackPanel>
                                <TextBlock Text="Bestätigt"  FontWeight="SemiBold"/>
                                <TextBlock x:Name="PlannerConfirmedCountTextBlock"
                                           Text="0"
                                           FontSize="22"
                                           FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <Border Margin="0,0,8,0"
                                Padding="10"
                                BorderThickness="1"
                                CornerRadius="8">
                            <StackPanel>
                                <TextBlock Text="Check-in" FontWeight="SemiBold"/>
                                <TextBlock x:Name="PlannerCheckedInCountTextBlock"
                                           Text="0"
                                           FontSize="22"
                                           FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <Border Margin="0,0,8,0"
                                Padding="10"
                                BorderThickness="1"
                                CornerRadius="8"
                                 Background="Khaki"
                                 BorderBrush="Goldenrod">
                            <StackPanel>
                                <TextBlock Text="In Behandlung" FontWeight="SemiBold"/>
                                <TextBlock x:Name="PlannerInTreatmentCountTextBlock"
                                           Text="0"
                                           FontSize="22"
                                           FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <Border Margin="0,0,8,0"
                                Padding="10"
                                BorderThickness="1"
                                CornerRadius="8"
                                 Background="LightGray"
                                 BorderBrush="Gray">
                            <StackPanel>
                                <TextBlock Text="Abgesagt" FontWeight="SemiBold"/>
                                <TextBlock x:Name="PlannerCancelledCountTextBlock"
                                           Text="0"
                                           FontSize="22"
                                           FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <Border Padding="10"
                                BorderThickness="1"
                                CornerRadius="8">
                            <StackPanel>
                                <TextBlock Text="Freie Slots" FontWeight="SemiBold"/>
                                <TextBlock x:Name="PlannerFreeSlotsCountTextBlock"
                                           Text="0"
                                           FontSize="22"
                                           FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                    <!-- Filterleiste -->
                    <Border Grid.Row="4"
                            Padding="10"
                            BorderThickness="1"
                            CornerRadius="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Raum:" VerticalAlignment="Center"/>
                            <ComboBox x:Name="PlannerRoomFilterComboBox"
                                      Grid.Column="1"
                                      Margin="0,0,12,0"
                                      SelectionChanged="PlannerFilter_Changed"/>

                            <TextBlock Grid.Column="2"
                                       Text="Status:"
                                       VerticalAlignment="Center"/>
                            <ComboBox x:Name="PlannerStatusFilterComboBox"
                                      Grid.Column="3"
                                      Margin="0,0,12,0"
                                      SelectionChanged="PlannerFilter_Changed"/>

                            <TextBlock Grid.Column="4"
                                       Text="Patient:"
                                       VerticalAlignment="Center"/>
                            <ComboBox x:Name="PlannerPatientFilterComboBox"
                                      Grid.Column="5"
                                      Margin="0,0,12,0"
                                      IsEditable="True"
                                      IsTextSearchEnabled="True"
                                      StaysOpenOnEdit="True"
                                      DisplayMemberPath="FullName"
                                      SelectedValuePath="Id"
                                      SelectionChanged="PlannerFilter_Changed"/>

                            <CheckBox x:Name="PlannerCheckedInOnlyCheckBox"
                                      Grid.Column="6"
                                      VerticalAlignment="Center"
                                      Content="Nur Check-in"
                                      Checked="PlannerFilter_Changed"
                                      Unchecked="PlannerFilter_Changed"/>

                            <CheckBox x:Name="PlannerActiveOnlyCheckBox"
                                      Grid.Column="7"
                                      VerticalAlignment="Center"
                                      Content="Nur aktiv"
                                      IsChecked="True"
                                      Checked="PlannerFilter_Changed"
                                      Unchecked="PlannerFilter_Changed"/>

                            <Button Grid.Column="8"
                                    Width="150"
                                    HorizontalAlignment="Right"
                                    Content="Filter zurücksetzen"
                                    Click="ResetPlannerFiltersButton_Click"/>
                        </Grid>
                    </Border>
                    <!-- Legende -->
                    <StackPanel Grid.Row="6" Orientation="Horizontal">
                        <Border Width="18" Height="18" Background="WhiteSmoke" BorderBrush="DarkGray" BorderThickness="1" Margin="0,0,6,0"/>
                        <TextBlock Text="Geplant" VerticalAlignment="Center" Margin="0,0,16,0"/>

                        <Border Width="18" Height="18" Background="LightGreen" BorderBrush="SeaGreen" BorderThickness="1" Margin="0,0,6,0"/>
                        <TextBlock Text="Bestätigt" VerticalAlignment="Center" Margin="0,0,16,0"/>

                        <Border Width="18" Height="18" Background="Khaki" BorderBrush="Goldenrod" BorderThickness="1" Margin="0,0,6,0"/>
                        <TextBlock Text="In Behandlung" VerticalAlignment="Center" Margin="0,0,16,0"/>

                        <Border Width="18" Height="18" Background="LightGray" BorderBrush="Gray" BorderThickness="1" Margin="0,0,6,0"/>
                        <TextBlock Text="Abgesagt" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    </StackPanel>
                    <!-- Kalender-ScrollViewer -->
                    <ScrollViewer Grid.Row="8"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto">
                        <Grid x:Name="RoomPlannerGrid"/>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Patientenfluss / Warteliste -->
            <Border Grid.Row="10" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Patientenfluss / Warteliste"
                               FontSize="18"
                               FontWeight="SemiBold"/>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>        <!-- Eingecheckt -->
                            <ColumnDefinition Width="12"/>

                            <ColumnDefinition Width="*"/>        <!-- Wartet -->
                            <ColumnDefinition Width="12"/>

                            <ColumnDefinition Width="*"/>         <!-- In Behandlung -->
                            <ColumnDefinition Width="12"/>

                            <ColumnDefinition Width="*"/>         <!-- Abgeschlossen -->
                        </Grid.ColumnDefinitions>

                        <!-- Eingecheckt -->
                        <Border Grid.Column="0"
                                Padding="10"
                                BorderThickness="1"
                                CornerRadius="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Eingecheckt"
                                           FontSize="16"
                                           FontWeight="SemiBold"/>

                                <ListBox Grid.Row="2"  x:Name="CheckedInPatientsListBox">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,8"
                                                    Padding="8"
                                                    BorderThickness="1"
                                                    CornerRadius="8">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}"
                                                                FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Subtitle}"
                                                               TextWrapping="Wrap"
                                                               Margin="0,2,0,0"/>
                                                    <StackPanel Orientation="Horizontal"
                                                                Margin="0,6,0,0">
                                                        <Button Content="Öffnen"
                                                                Margin="0,0,6,0"
                                                                Tag="{Binding AppointmentId}"
                                                                Click="FlowOpenButton_Click"/>
                                                        <Button Content="→ Wartet"
                                                                Tag="{Binding AppointmentId}"
                                                                Click="MoveToWaitingButton_Click"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <!-- Wartet -->
                        <Border Grid.Column="2"
                                Padding="10"
                                BorderThickness="1"
                                CornerRadius="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Wartet"
                                           FontSize="16"
                                           FontWeight="SemiBold"/>

                                <ListBox Grid.Row="2"
                                         x:Name="WaitingPatientsListBox">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,8"
                                                    Padding="8"
                                                    BorderThickness="1"
                                                    CornerRadius="8">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}"
                                                                 FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Subtitle}"
                                                               TextWrapping="Wrap"
                                                               Margin="0,2,0,0"/>
                                                    <StackPanel Orientation="Horizontal"
                                                                Margin="0,6,0,0">
                                                        <Button Content="Öffnen"
                                                                Margin="0,0,6,0"
                                                                Tag="{Binding AppointmentId}"
                                                                Click="FlowOpenButton_Click"/>
                                                        <Button Content="→ In Behandlung"
                                                                Tag="{Binding AppointmentId}"
                                                                Click="MoveToInTreatmentButton_Click"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <!-- In Behandlung -->
                        <Border Grid.Column="4"
                                Padding="10"
                                BorderThickness="1"
                                CornerRadius="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="In Behandlung"
                                           FontSize="16"
                                           FontWeight="SemiBold"/>

                                <ListBox Grid.Row="2"
                                        x:Name="InTreatmentPatientsListBox">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,8"
                                                    Padding="8"
                                                    BorderThickness="1"
                                                    CornerRadius="8">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}"
                                                                FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Subtitle}"
                                                               TextWrapping="Wrap"
                                                               Margin="0,2,0,0"/>
                                                    <StackPanel Orientation="Horizontal"
                                                                Margin="0,6,0,0">
                                                        <Button Content="Öffnen"
                                                                Margin="0,0,6,0"
                                                                Tag="{Binding AppointmentId}"
                                                                Click="FlowOpenButton_Click"/>
                                                        <Button Content="→ Abschließen"
                                                                Tag="{Binding AppointmentId}"
                                                                Click="MoveToCompletedButton_Click"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <!-- Abgeschlossen -->
                        <Border Grid.Column="6"
                                Padding="10"
                                BorderThickness="1"
                                CornerRadius="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Abgeschlossen"
                                           FontSize="16"
                                           FontWeight="SemiBold"/>

                                <ListBox Grid.Row="2"
                                        x:Name="CompletedPatientsListBox">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,8"
                                                    Padding="8"
                                                    BorderThickness="1"
                                                    CornerRadius="8">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}"
                                                                FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Subtitle}"
                                                               TextWrapping="Wrap"
                                                               Margin="0,2,0,0"/>
                                                    <Button Content="Öffnen"
                                                            Margin="0,6,0,0"
                                                            HorizontalAlignment="Left"
                                                            Tag="{Binding AppointmentId}"
                                                            Click="FlowOpenButton_Click"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- Terminliste -->
            <Border Grid.Row="12"
                    Style="{StaticResource CardBorderStyle}">
                <DataGrid x:Name="AppointmentsGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          SelectionChanged="AppointmentsGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70"/>
                        <DataGridTextColumn Header="Patient" Binding="{Binding Patient.FullName}" Width="180"/>
                        <DataGridTextColumn Header="Beginn" Binding="{Binding StartTime, StringFormat=dd.MM.yyyy HH:mm}" Width="170"/>
                        <DataGridTextColumn Header="Ende" Binding="{Binding EndTime, StringFormat=dd.MM.yyyy HH:mm}" Width="170"/>
                        <DataGridTextColumn Header="Dauer" Binding="{Binding DurationMinutes}" Width="90"/>
                        <DataGridTextColumn Header="Raum" Binding="{Binding RoomName}" Width="140"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                        <DataGridTextColumn Header="Grund" Binding="{Binding Reason}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>