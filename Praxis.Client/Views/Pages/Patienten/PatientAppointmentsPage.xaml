<UserControl x:Class="Praxis.Client.Views.Pages.Patienten.PatientAppointmentsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">  

        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="220"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="260"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Patiententermine" Style="{StaticResource SectionTitleStyle}"/>

            <!-- Patientendaten -->
            <Border Grid.Row="2"
                Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="320"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Patient:" VerticalAlignment="Center"/>
                    <TextBox x:Name="PatientNameTextBox"
                         Grid.Column="1"
                         Margin="0,4,0,4"
                         IsReadOnly="True"/>

                    <TextBlock Grid.Row="1" Text="Geburtsdatum:" VerticalAlignment="Center"/>
                    <TextBox x:Name="GeburtsdatumTextBox"
                         Grid.Row="1"
                         Grid.Column="1"
                         Margin="0,4,0,4"
                         IsReadOnly="True"/>

                    <TextBlock Grid.Row="2" Text="Telefon:" VerticalAlignment="Center"/>
                    <TextBox x:Name="TelefonTextBox"
                         Grid.Row="2"
                         Grid.Column="1"
                         Margin="0,4,0,4"
                         IsReadOnly="True"/>

                    <TextBlock Grid.Column="3" Text="E-Mail:" VerticalAlignment="Center"/>
                    <TextBox x:Name="EmailTextBox"
                         Grid.Column="4"
                         Margin="0,4,0,4"
                         IsReadOnly="True"/>

                    <TextBlock Grid.Row="1"
                           Grid.Column="3"
                           Text="Hinweis:"
                           VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="1"
                           Grid.Column="4"
                           Text="Datum, Dauer und Raum wählen – freie Slots werden automatisch berechnet."
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource MutedTextBrush}"/>
                </Grid>
            </Border>

            <!-- Terminformular -->
            <Border Grid.Row="4"
                Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="260"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="42"/>
                        <RowDefinition Height="42"/>
                        <RowDefinition Height="42"/>
                        <RowDefinition Height="42"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Datum:" VerticalAlignment="Center"/>
                    <DatePicker x:Name="AppointmentDatePicker"
                            Grid.Column="1"
                            Margin="0,4,0,4"
                            SelectedDateChanged="AppointmentCriteria_Changed"/>

                    <TextBlock Grid.Column="3"
                           Text="Uhrzeit (HH:mm):"
                           VerticalAlignment="Center"/>
                    <TextBox x:Name="AppointmentTimeTextBox"
                         Grid.Column="4"
                         Margin="0,4,0,4"
                         Text="09:00"/>

                    <TextBlock Grid.Row="1"
                           Text="Dauer (Minuten):"
                           VerticalAlignment="Center"/>
                    <TextBox x:Name="DurationTextBox"
                         Grid.Row="1"
                         Grid.Column="1"
                         Margin="0,4,0,4"
                         Text="30"
                         TextChanged="AppointmentCriteria_Changed"/>

                    <TextBlock Grid.Row="1"
                           Grid.Column="3"
                           Text="Raum:"
                           VerticalAlignment="Center"/>
                    <ComboBox x:Name="RoomComboBox"
                          Grid.Row="1"
                          Grid.Column="4"
                          Margin="0,4,0,4"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Name"
                          SelectionChanged="AppointmentCriteria_Changed"/>

                    <TextBlock Grid.Row="2"
                           Text="Grund:"
                           VerticalAlignment="Center"/>
                    <TextBox x:Name="ReasonTextBox"
                         Grid.Row="2"
                         Grid.Column="1"
                         Margin="0,4,0,4"/>

                    <TextBlock Grid.Row="2"
                           Grid.Column="3"
                           Text="Status:"
                           VerticalAlignment="Center"/>
                    <ComboBox x:Name="StatusComboBox"
                          Grid.Row="2"
                          Grid.Column="4"
                          Margin="0,4,0,4">
                        <ComboBoxItem Content="Geplant" IsSelected="True"/>
                        <ComboBoxItem Content="Bestätigt"/>
                        <ComboBoxItem Content="Verschoben"/>
                        <ComboBoxItem Content="Abgesagt"/>
                    </ComboBox>

                    <StackPanel Grid.Row="3"
                            Grid.ColumnSpan="5"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                        <Button Content="Freie Slots aktualisieren"
                            Width="150"
                            Margin="0,0,8,0"
                            Click="RefreshSlotsButton_Click"/>

                        <Button Content="Neu"
                            Width="90"
                            Margin="0,0,8,0"
                            Click="NewAppointmentButton_Click"/>

                        <Button Content="Speichern"
                            Width="100"
                            Margin="0,0,8,0"
                            Style="{StaticResource SuccessButtonStyle}"
                            Click="SaveAppointmentButton_Click"/>

                        <Button Content="Löschen"
                            Width="90"
                            Margin="0,0,8,0"
                            Click="DeleteAppointmentButton_Click"/>

                        <Button Content="Zurück zur Suche"
                            Width="140"
                            Click="BackButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Freie Slots -->
            <Border Grid.Row="6"
                Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Freie Zeitfenster"
                           FontSize="18"
                           FontWeight="SemiBold"/>

                    <ListBox Grid.Row="2"
                         x:Name="AvailableSlotsListBox"
                         SelectionChanged="AvailableSlotsListBox_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10"
                                    Margin="0,0,0,6"
                                    BorderThickness="1"
                                    CornerRadius="8">
                             <TextBlock Text="{Binding SlotLabel}"/>                                    
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                </Grid>
            </Border>

        <!-- Raumplaner / Rasteransicht -->
        <Border Grid.Row="8" Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Kalender-Raumplaner"
                       FontSize="18"
                       FontWeight="SemiBold"/>

                    <TextBlock Text="  (15-Minuten-Raster)"
                       Margin="8,2,0,0"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource MutedTextBrush}"/>
                </StackPanel>

                <ScrollViewer Grid.Row="2"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
                    <Grid x:Name="RoomPlannerGrid"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Terminliste -->
            <Border Grid.Row="10"
                Style="{StaticResource CardBorderStyle}">
                <DataGrid x:Name="AppointmentsGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      SelectionChanged="AppointmentsGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70"/>
                        <DataGridTextColumn Header="Beginn" Binding="{Binding StartTime, StringFormat=dd.MM.yyyy HH:mm}" Width="170"/>
                        <DataGridTextColumn Header="Ende" Binding="{Binding EndTime, StringFormat=dd.MM.yyyy HH:mm}" Width="170"/>
                        <DataGridTextColumn Header="Dauer" Binding="{Binding DurationMinutes}" Width="90"/>
                        <DataGridTextColumn Header="Raum" Binding="{Binding RoomName}" Width="140"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                        <DataGridTextColumn Header="Grund" Binding="{Binding Reason}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </UserControl>