<UserControl x:Class="Praxis.Client.Views.Pages.Patienten.PatientSearchPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Patientensuche"
                   Style="{StaticResource SectionTitleStyle}"
                   Margin="0,0,0,10"/>

        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SearchTextBox"
                         Grid.Column="0"
                         Height="34"
                         Style="{StaticResource SearchTextBoxStyle}"
                         Tag="Patient suchen..."
                         TextChanged="SearchTextBox_TextChanged"/>
                <Button Grid.Column="1"
                        Content="Suchen"
                        Margin="10,0,0,0"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="SearchButton_Click"/>
                <Button Grid.Column="2"
                         Content="Neu laden"
                         Margin="10,0,0,0"
                         Click="ReloadButton_Click"/>
                <TextBlock Grid.Column="3"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0"
                           Foreground="{DynamicResource MutedTextBrush}"
                           Text="Suche nach Vorname, Nachname, Telefon oder E-Mail"/>
            </Grid>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource CardBorderStyle}">
            <DataGrid x:Name="PatientsGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      SelectionMode="Single"
                      SelectionChanged="PatientsGrid_SelectionChanged"
                      MouseDoubleClick="PatientsGrid_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="80"/>
                    <DataGridTextColumn Header="Vorname" Binding="{Binding FirstName}" Width="*"/>
                    <DataGridTextColumn Header="Nachname" Binding="{Binding LastName}" Width="*"/>
                    <DataGridTextColumn Header="Geburtsdatum" Binding="{Binding DateOfBirth}" Width="160"/>
                    <DataGridTextColumn Header="Telefon" Binding="{Binding Phone}" Width="160"/>
                    <DataGridTextColumn Header="E-Mail" Binding="{Binding Email}" Width="220"/>
                    <DataGridCheckBoxColumn Header="Aktiv" Binding="{Binding IsActive}" Width="80"/>
                    <DataGridTextColumn Header="Adresse" Binding="{Binding Adresse}" Width="220"/>
                    <DataGridTextColumn Header="PLZ" Binding="{Binding PLZ}" Width="90"/>
                    <DataGridTextColumn Header="Ort" Binding="{Binding Ort}" Width="140"/>
                    <DataGridTextColumn Header="Versicherung" Binding="{Binding Versicherung}" Width="130"/>
                    <DataGridTextColumn Header="Geschlecht" Binding="{Binding Geschlecht}" Width="110"/>
                    <DataGridTextColumn Header="Versichertennr." Binding="{Binding Versichertennummer}" Width="160"/>
                    
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>