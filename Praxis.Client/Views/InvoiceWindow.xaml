<Window x:Class="Praxis.Client.Views.InvoiceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rechnungen"
        Height="600"
        Width="1000"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Rechnungsübersicht"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,12"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Patient:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox x:Name="PatientFilterBox" Width="180" Margin="0,0,12,0" TextChanged="Filter_Changed"/>
            <TextBlock Text="Von:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <DatePicker x:Name="FromDatePicker" Width="140" SelectedDateChanged="Filter_Changed"/>
            <TextBlock Text="Bis:" VerticalAlignment="Center" Margin="12,0,8,0"/>
            <DatePicker x:Name="ToDatePicker" Width="140" SelectedDateChanged="Filter_Changed"/>
            <Button Content="Neu" Width="100" Margin="20,0,0,0" Click="NewInvoice_Click"/>
            <Button Content="PDF exportieren" Width="140" Margin="10,0,0,0" Click="ExportPdf_Click"/>
            <Button Content="Rechnung löschen" Width="140" Margin="8,0,0,0" Click="DeleteInvoice_Click"></Button>

        </StackPanel>

        <DataGrid x:Name="InvoicesGrid"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nr." Binding="{Binding InvoiceNumber}" Width="180"/>
                <DataGridTextColumn Header="Datum" Binding="{Binding InvoiceDate, StringFormat=d}" Width="120"/>
                <DataGridTextColumn Header="Patient" Binding="{Binding Patient.FullName}" Width="*"/>
                <DataGridTextColumn Header="Gesamtbetrag" Binding="{Binding TotalAmount, StringFormat={}{0:N2} €}" Width="140"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>