<Window x:Class="Praxis.Client.Views.DocumentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dokumente"
        Height="640"
        Width="1180"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource CardBorderStyle}"
                Margin="0,0,0,12"
                Background="{StaticResource HeaderPanelBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Dokumentenverwaltung"
                               Style="{StaticResource SectionTitleStyle}"/>
                    <TextBlock Text="Patientendokumente anzeigen, pflegen und verwalten"
                               Foreground="{StaticResource MutedTextBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <TextBox x:Name="SearchBox"
                             Width="250"
                             Height="32"
                             Style="{StaticResource SearchTextBoxStyle}"
                             Tag="Dokument suchen..."/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource CardBorderStyle}"
                Margin="0,0,0,12">
            <WrapPanel>
                <Button Height="34" Width="130" Margin="0,0,8,8"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="AddDocument_Click">
                    Dokument neu
                </Button>

                <Button Height="34" Width="120" Margin="0,0,8,8"
                        Click="OpenDocument_Click">
                    Öffnen
                </Button>

                <Button Height="34" Width="120" Margin="0,0,8,8"
                        Click="EditDocument_Click">
                    Bearbeiten
                </Button>

                <Button Height="34" Width="120" Margin="0,0,8,8"
                        Style="{StaticResource DangerButtonStyle}"
                        Click="DeleteDocument_Click">
                    Löschen
                </Button>

                <Button Height="34" Width="130"
                        Click="Refresh_Click">
                    Aktualisieren
                </Button>
            </WrapPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="290"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource CardBorderStyle}"
                    Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Dokumentenliste"
                                   FontSize="16"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Zugeordnete Dateien und Praxisdokumente"
                                   FontSize="12"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                    <Border Grid.Row="1"
                            BorderBrush="{StaticResource BorderBrushCustom}"
                            BorderThickness="1"
                            Background="White">
                        <DataGrid x:Name="DocumentsGrid"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  RowHeaderWidth="0"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Titel" Binding="{Binding Title}" Width="*"/>
                                <DataGridTextColumn Header="Patient" Binding="{Binding PatientName}" Width="180"/>
                                <DataGridTextColumn Header="Kategorie" Binding="{Binding Category}" Width="140"/>
                                <DataGridTextColumn Header="Datum" Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy}" Width="120"/>
                                <DataGridTextColumn Header="Datei" Binding="{Binding FileName}" Width="220"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </Border>

            <StackPanel Grid.Column="1">
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Dokumentinfo"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="Titel" Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBlock x:Name="SelectedDocumentTitleText"
                                   Text="-"
                                   Margin="0,0,0,8"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="Patient" Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBlock x:Name="SelectedDocumentPatientText"
                                   Text="-"
                                   Margin="0,0,0,8"/>

                        <TextBlock Text="Kategorie" Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBlock x:Name="SelectedDocumentCategoryText"
                                   Text="-"
                                   Margin="0,0,0,8"/>

                        <TextBlock Text="Datei" Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBlock x:Name="SelectedDocumentFileText"
                                   Text="-"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Hinweise"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,10"/>
                        <TextBlock Text="• Dokumente sollten einem Patienten eindeutig zugeordnet sein."
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="• Unterstütze später PDF, Scan und Vorlagen als eigene Kategorien."
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource MutedTextBrush}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Window>