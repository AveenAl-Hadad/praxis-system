<Window x:Class="Praxis.Client.Views.DocumentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Patient Dokumente"
        Height="500"
        Width="800">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Dokumente"
           FontSize="22"
           FontWeight="Bold"
           Margin="0,0,0,10"/>

        <DataGrid x:Name="DocumentsGrid"
          Grid.Row="1"
          AutoGenerateColumns="False">

            <DataGrid.Columns>

                <DataGridTextColumn Header="Datei" 
                                    Binding="{Binding FileName}" Width="*"/>

                <DataGridTextColumn Header="Datum" 
                                    Binding="{Binding UploadDate, StringFormat=dd.MM.yyyy}"
                                    Width="120"/>

            </DataGrid.Columns>

        </DataGrid>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">

            <Button Content="Hochladen"
                    Width="120"
                    Margin="0,0,10,0"
                    Click="Upload_Click"/>

            <Button Content="Öffnen"
                    Width="120"
                    Click="Open_Click"/>

        </StackPanel>

    </Grid>
</Window>