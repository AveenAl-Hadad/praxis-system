<Window x:Class="Praxis.Client.AddAppointmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Termin anlegen"
        Height="420"
        Width="400"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Patient" Margin="0,0,0,5"/>
        <ComboBox x:Name="PatientComboBox"
                  Grid.Row="1"
                  Height="30"
                  Margin="0,0,0,10"
                  DisplayMemberPath="FullName"
                  SelectedValuePath="Id"/>

        <TextBlock Grid.Row="2" Text="Datum" Margin="0,0,0,5"/>
        <DatePicker x:Name="AppointmentDatePicker"
                    Grid.Row="3"
                    Height="30"
                    Margin="0,0,0,10"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,10">
            <StackPanel Width="150">
                <TextBlock Text="Uhrzeit (HH:mm)" Margin="0,0,0,5"/>
                <TextBox x:Name="TimeTextBox" Height="30"/>
            </StackPanel>

            <StackPanel Width="150" Margin="20,0,0,0">
                <TextBlock Text="Dauer (Min.)" Margin="0,0,0,5"/>
                <TextBox x:Name="DurationTextBox" Height="30"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="5">
            <TextBlock Text="Grund" Margin="0,0,0,5"/>
            <TextBox x:Name="ReasonTextBox"
                     Height="80"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"/>
        </StackPanel>

        <Button Grid.Row="6"
                Content="Termin speichern"
                Width="140"
                Height="35"
                HorizontalAlignment="Right"
                Margin="0,15,0,0"
                Click="SaveAppointment_Click"/>
    </Grid>
</Window>