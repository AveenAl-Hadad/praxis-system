<Window x:Class="Praxis.Client.Views.AddAppointmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Termin anlegen"
        Height="560"
        Width="760"
        MinHeight="520"
        MinWidth="700"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Kopf -->
        <Border Grid.Row="0"
                Style="{StaticResource CardBorderStyle}"
                Margin="0,0,0,12"
                Background="{StaticResource HeaderPanelBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Termin anlegen"
                               Style="{StaticResource SectionTitleStyle}"/>
                    <TextBlock Text="Neue Terminbuchung für Patient, Zeit und Status erfassen"
                               Foreground="{StaticResource MutedTextBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#EAF6F8"
                        BorderBrush="{StaticResource PrimaryBrush}"
                        BorderThickness="1"
                        CornerRadius="3"
                        Padding="10"
                        HorizontalAlignment="Right">
                    <StackPanel>
                        <TextBlock Text="Modul"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Terminplanung"
                                   Margin="0,4,0,0"
                                   Foreground="{StaticResource MutedTextBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Formular -->
        <Border Grid.Row="1"
                Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="230"/>
                </Grid.ColumnDefinitions>

                <!-- Formular links -->
                <Grid Grid.Column="0" Margin="0,0,12,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Text="Patient"
                               Margin="0,0,12,12"
                               VerticalAlignment="Center"/>
                    <ComboBox x:Name="PatientComboBox"
                              Grid.Row="0"
                              Grid.Column="1"
                              Height="32"
                              Margin="0,0,0,12"
                              DisplayMemberPath="FullName"
                              SelectedValuePath="Id"/>

                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               Text="Datum"
                               Margin="0,0,12,12"
                               VerticalAlignment="Center"/>
                    <DatePicker x:Name="AppointmentDatePicker"
                                Grid.Row="1"
                                Grid.Column="1"
                                Height="32"
                                Margin="0,0,0,12"/>

                    <TextBlock Grid.Row="2"
                               Grid.Column="0"
                               Text="Uhrzeit"
                               Margin="0,0,12,12"
                               VerticalAlignment="Center"/>
                    <TextBox x:Name="TimeTextBox"
                             Grid.Row="2"
                             Grid.Column="1"
                             Height="32"
                             Margin="0,0,0,12"/>

                    <TextBlock Grid.Row="3"
                               Grid.Column="0"
                               Text="Dauer (Min.)"
                               Margin="0,0,12,12"
                               VerticalAlignment="Center"/>
                    <TextBox x:Name="DurationTextBox"
                             Grid.Row="3"
                             Grid.Column="1"
                             Height="32"
                             Margin="0,0,0,12"/>

                    <TextBlock Grid.Row="4"
                               Grid.Column="0"
                               Text="Grund"
                               Margin="0,0,12,0"
                               VerticalAlignment="Top"/>
                    <TextBox x:Name="ReasonTextBox"
                             Grid.Row="4"
                             Grid.Column="1"
                             Height="110"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"/>
                </Grid>

                <!-- Rechte Spalte -->
                <StackPanel Grid.Column="1">
                    <Border Background="#F3F5F6"
                            BorderBrush="{StaticResource BorderBrushCustom}"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="10"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Terminstatus"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10"/>

                            <ComboBox x:Name="StatusComboBox"
                                      Height="32"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#F3F5F6"
                            BorderBrush="{StaticResource BorderBrushCustom}"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="10">
                        <StackPanel>
                            <TextBlock Text="Hinweise"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10"/>

                            <TextBlock Text="• Uhrzeit im Format HH:mm eingeben."
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8"
                                       Foreground="{StaticResource MutedTextBrush}"/>

                            <TextBlock Text="• Dauer in Minuten angeben, z. B. 15 oder 30."
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8"
                                       Foreground="{StaticResource MutedTextBrush}"/>

                            <TextBlock Text="• Der Terminstatus kann direkt beim Anlegen gesetzt werden."
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource MutedTextBrush}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="2"
                Style="{StaticResource CardBorderStyle}"
                Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Termin speichern und in die Übersicht übernehmen"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource MutedTextBrush}"/>

                <Button Grid.Column="1"
                        Content="Termin speichern"
                        Width="150"
                        Height="34"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="SaveAppointment_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>