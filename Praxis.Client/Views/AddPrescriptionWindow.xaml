<Window x:Class="Praxis.Client.Views.AddPrescriptionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rezept erstellen"
        Height="500"
        Width="700"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Neues Rezept"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,12"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Patient:" Width="100" VerticalAlignment="Center"/>
            <ComboBox x:Name="PatientComboBox"
                      Width="320"
                      DisplayMemberPath="FullName"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Medikament:" Width="100" VerticalAlignment="Center"/>
            <TextBox x:Name="MedicationBox" Width="320"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Dosierung:" Width="100" VerticalAlignment="Center"/>
            <TextBox x:Name="DosageBox" Width="320"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Arzt:" Width="100" VerticalAlignment="Center"/>
            <TextBox x:Name="DoctorNameBox" Width="320"/>
        </StackPanel>

        <StackPanel Grid.Row="5">
            <TextBlock Text="Anweisung:" Margin="0,0,0,6"/>
            <TextBox x:Name="InstructionsBox"
                     AcceptsReturn="True"
                     Height="120"
                     TextWrapping="Wrap"/>
        </StackPanel>

        <StackPanel Grid.Row="6"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Speichern"
                    Width="120"
                    Margin="0,0,8,0"
                    Click="Save_Click"/>
            <Button Content="Abbrechen"
                    Width="120"
                    Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>