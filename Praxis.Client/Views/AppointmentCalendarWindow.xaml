<Window x:Class="Praxis.Client.Views.AppointmentCalendarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kalenderansicht"
        Height="600"
        Width="1100"
        WindowStartupLocation="CenterOwner">

    <DockPanel Margin="12">

        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Text="Wochenstart:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <DatePicker x:Name="WeekDatePicker"
                        Width="140"
                        SelectedDateChanged="WeekDatePicker_SelectedDateChanged"/>

            <TextBlock Text="Patient:" VerticalAlignment="Center" Margin="20,0,8,0"/>
            <ComboBox x:Name="PatientFilterComboBox"
                      Width="220"
                      DisplayMemberPath="FullName"
                      SelectedValuePath="Id"
                      SelectionChanged="PatientFilterComboBox_SelectionChanged"/>

            <Button Content="Alle"
                    Width="80"
                    Margin="10,0,0,0"
                    Click="ShowAllPatients_Click"/>

            <Button Content="Aktualisieren"
                    Width="110"
                    Margin="20,0,0,0"
                    Click="RefreshButton_Click"/>
        </StackPanel>

        <DataGrid x:Name="CalendarDataGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  MouseDoubleClick="CalendarDataGrid_MouseDoubleClick">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Status}" Value="Geplant">
                            <Setter Property="Background" Value="LightYellow"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Status}" Value="Bestätigt">
                            <Setter Property="Background" Value="LightGreen"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Status}" Value="Abgesagt">
                            <Setter Property="Background" Value="LightCoral"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Status}" Value="Erledigt">
                            <Setter Property="Background" Value="LightBlue"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Tag"
                                    Binding="{Binding StartTime, StringFormat=dddd}"
                                    Width="120"/>
                <DataGridTextColumn Header="Datum"
                                    Binding="{Binding StartTime, StringFormat=dd.MM.yyyy}"
                                    Width="120"/>
                <DataGridTextColumn Header="Uhrzeit"
                                    Binding="{Binding StartTime, StringFormat=HH:mm}"
                                    Width="90"/>
                <DataGridTextColumn Header="Patient"
                                    Binding="{Binding Patient.FullName}"
                                    Width="180"/>
                <DataGridTextColumn Header="Dauer"
                                    Binding="{Binding DurationMinutes}"
                                    Width="80"/>
                <DataGridTextColumn Header="Grund"
                                    Binding="{Binding Reason}"
                                    Width="*"/>
                <DataGridTextColumn Header="Status"
                                    Binding="{Binding Status}"
                                    Width="120"/>

                <DataGridTemplateColumn Header="Aktionen" Width="180">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Bearbeiten"
                                        Margin="0,0,6,0"
                                        Padding="8,2"
                                        Click="EditAppointment_Click"/>
                                <Button Content="Löschen"
                                        Padding="8,2"
                                        Click="DeleteAppointment_Click"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>