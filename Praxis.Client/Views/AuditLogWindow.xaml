<Window x:Class="Praxis.Client.Views.AuditLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Praxis.Client.Views"
        mc:Ignorable="d"
        Title="Systemprotokoll" Height="600" Width="900">
    <Grid Margin="12">

        <DataGrid x:Name="AuditGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">

            <DataGrid.Columns>

                <DataGridTextColumn Header="Zeit"
                                    Binding="{Binding Timestamp}"
                                    Width="180"/>

                <DataGridTextColumn Header="Benutzer"
                                    Binding="{Binding UserName}"
                                    Width="140"/>

                <DataGridTextColumn Header="Aktion"
                                    Binding="{Binding Action}"
                                    Width="120"/>

                <DataGridTextColumn Header="Entity"
                                    Binding="{Binding EntityType}"
                                    Width="120"/>

                <DataGridTextColumn Header="Details"
                                    Binding="{Binding Details}"
                                    Width="*"/>

            </DataGrid.Columns>

        </DataGrid>


    </Grid>
</Window>
