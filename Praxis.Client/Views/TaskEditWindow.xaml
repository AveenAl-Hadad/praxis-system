<Window x:Class="Praxis.Client.Views.TaskEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aufgabe"
        Height="420"
        Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="130"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0"
                   Text="Titel:"
                   VerticalAlignment="Center"
                   Margin="0,0,10,0"/>
        <TextBox Grid.Row="0" Grid.Column="1"
                 x:Name="TitleTextBox"
                 MinWidth="250"/>

        <TextBlock Grid.Row="2" Grid.Column="0"
                   Text="Beschreibung:"
                   VerticalAlignment="Top"
                   Margin="0,4,10,0"/>
        <TextBox Grid.Row="2" Grid.Column="1"
                 x:Name="DescriptionTextBox"
                 Height="90"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"/>

        <TextBlock Grid.Row="4" Grid.Column="0"
                   Text="Priorität:"
                   VerticalAlignment="Center"
                   Margin="0,0,10,0"/>
        <ComboBox Grid.Row="4" Grid.Column="1"
                  x:Name="PriorityComboBox"
                  SelectedIndex="1">
            <ComboBoxItem Content="Niedrig"/>
            <ComboBoxItem Content="Normal"/>
            <ComboBoxItem Content="Hoch"/>
        </ComboBox>

        <TextBlock Grid.Row="6" Grid.Column="0"
                   Text="Fällig am:"
                   VerticalAlignment="Center"
                   Margin="0,0,10,0"/>
        <DatePicker Grid.Row="6" Grid.Column="1"
                    x:Name="DueDatePicker"/>

        <TextBlock Grid.Row="8" Grid.Column="0"
                   Text="Zuständig:"
                   VerticalAlignment="Center"
                   Margin="0,0,10,0"/>
        <TextBox Grid.Row="8" Grid.Column="1"
                 x:Name="AssignedToTextBox"/>

        <StackPanel Grid.Row="10" Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Speichern"
                    Width="110"
                    Margin="0,0,10,0"
                    Click="SaveButton_Click"/>
            <Button Content="Abbrechen"
                    Width="110"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>