<Window x:Class="Praxis.Client.Views.UserManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Benutzerverwaltung"
        Height="700"
        Width="1160"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource CardBorderStyle}"
                Margin="0,0,0,12"
                Background="{StaticResource HeaderPanelBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="240"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Benutzerverwaltung"
                               Style="{StaticResource SectionTitleStyle}"/>
                    <TextBlock Text="Benutzer, Rollen und Zugriffsrechte verwalten"
                               Foreground="{StaticResource MutedTextBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#EAF6F8"
                        BorderBrush="{StaticResource PrimaryBrush}"
                        BorderThickness="1"
                        CornerRadius="3"
                        Padding="10"
                        HorizontalAlignment="Right">
                    <StackPanel>
                        <TextBlock Text="Administration"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Benutzer &amp; Rechte"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource CardBorderStyle}"
                Margin="0,0,0,12">
            <WrapPanel>
                <Button Width="130" Height="34" Margin="0,0,8,8"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="AddUser_Click">
                    Benutzer neu
                </Button>

                <Button Width="120" Height="34" Margin="0,0,8,8"
                        Click="EditUser_Click">
                    Bearbeiten
                </Button>

                <Button Width="120" Height="34" Margin="0,0,8,8"
                        Style="{StaticResource DangerButtonStyle}"
                        Click="DeleteUser_Click">
                    Löschen
                </Button>

                <Button Width="150" Height="34" Margin="0,0,8,8"
                        Click="ResetPassword_Click">
                    Passwort zurücksetzen
                </Button>

                <Button Width="130" Height="34"
                        Click="Refresh_Click">
                    Aktualisieren
                </Button>
            </WrapPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource CardBorderStyle}"
                    Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Benutzerliste"
                                   FontSize="16"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Alle Benutzerkonten mit Rolle und Aktivstatus"
                                   FontSize="12"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                    <Border Grid.Row="1"
                            BorderBrush="{StaticResource BorderBrushCustom}"
                            BorderThickness="1"
                            Background="White">
                        <DataGrid x:Name="UsersGrid"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  RowHeaderWidth="0"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  SelectionChanged="UsersGrid_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Benutzername" Binding="{Binding Username}" Width="*"/>
                                <DataGridTextColumn Header="Rolle" Binding="{Binding Role}" Width="160"/>
                                <DataGridCheckBoxColumn Header="Aktiv" Binding="{Binding IsActive}" Width="80"/>
                                <DataGridTextColumn Header="Erstellt am" Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy}" Width="130"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </Border>

            <StackPanel Grid.Column="1">
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Benutzerinfo"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Margin="0,0,0,10"/>

                        <TextBlock Text="Benutzername" Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBlock x:Name="SelectedUsernameText"
                       Text="-"
                       Margin="0,0,0,8"
                       FontWeight="SemiBold"/>

                        <TextBlock Text="Rolle" Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBlock x:Name="SelectedUserRoleText"
                       Text="-"
                       Margin="0,0,0,8"/>

                        <TextBlock Text="Status" Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBlock x:Name="SelectedUserStatusText"
                       Text="-"/>
                    </StackPanel>
                </Border>

                <!-- HIER EINFÜGEN -->
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Benutzerdaten"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Margin="0,0,0,10"/>

                        <TextBlock Text="Benutzername"
                       Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBox x:Name="UsernameTextBox"
                     Margin="0,0,0,8"/>

                        <TextBlock Text="Passwort"
                       Foreground="{StaticResource MutedTextBrush}"/>
                        <PasswordBox x:Name="PasswordBox"
                         Margin="0,0,0,8"/>

                        <TextBlock Text="Rolle"
                       Foreground="{StaticResource MutedTextBrush}"/>
                        <ComboBox x:Name="RoleComboBox"
                      Margin="0,0,0,8"/>

                        <TextBlock Text="Rolle bearbeiten"
                       Foreground="{StaticResource MutedTextBrush}"/>
                        <ComboBox x:Name="EditRoleComboBox"/>

                   
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Hinweise"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Margin="0,0,0,10"/>
                        <TextBlock Text="• Benutzerrechte sollten nach Rollen getrennt bleiben."
                       TextWrapping="Wrap"
                       Foreground="{StaticResource MutedTextBrush}"
                       Margin="0,0,0,8"/>
                        <TextBlock Text="• Später kannst du feingranulare Rechte pro Modul ergänzen."
                       TextWrapping="Wrap"
                       Foreground="{StaticResource MutedTextBrush}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Window>