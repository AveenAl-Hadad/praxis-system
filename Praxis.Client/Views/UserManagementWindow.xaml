<Window x:Class="Praxis.Client.Views.UserManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Benutzerverwaltung"
        Height="560"
        Width="920"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Header="Neuen Benutzer anlegen" Margin="0,0,0,10">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Benutzername" Margin="0,0,0,4"/>
                    <TextBox x:Name="UsernameTextBox" Height="30"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Text="Passwort" Margin="0,0,0,4"/>
                    <PasswordBox x:Name="PasswordBox" Height="30"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,10,0">
                    <TextBlock Text="Rolle" Margin="0,0,0,4"/>
                    <ComboBox x:Name="RoleComboBox" Height="30"/>
                </StackPanel>

                <Button Grid.Column="3"
                        Content="Benutzer anlegen"
                        Width="150"
                        Height="30"
                        VerticalAlignment="Bottom"
                        Click="CreateUser_Click"/>
            </Grid>
        </GroupBox>

        <DataGrid Grid.Row="1"
                  x:Name="UsersGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70"/>
                <DataGridTextColumn Header="Benutzername" Binding="{Binding Username}" Width="*"/>
                <DataGridTextColumn Header="Rolle" Binding="{Binding Role}" Width="180"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <TextBlock Text="Neue Rolle" Margin="0,0,0,4"/>
                <ComboBox x:Name="EditRoleComboBox" Height="30"/>
            </StackPanel>

            <Button Grid.Column="1"
                    Content="Rolle ändern"
                    Width="130"
                    Height="30"
                    VerticalAlignment="Bottom"
                    Margin="0,0,10,0"
                    Click="ChangeRole_Click"/>

            <Button Grid.Column="2"
                    Content="Passwort zurücksetzen"
                    Width="140"
                    Height="30"
                    VerticalAlignment="Bottom"
                    Margin="0,0,10,0"
                    Click="ResetPassword_Click"/>

            <Button Grid.Column="3"
                    Content="Benutzer löschen"
                    Width="130"
                    Height="30"
                    VerticalAlignment="Bottom"
                    Margin="0,0,10,0"
                    Click="DeleteUser_Click"/>

            <Button Grid.Column="5"
                    Content="Schließen"
                    Width="110"
                    Height="30"
                    VerticalAlignment="Bottom"
                    Click="Close_Click"/>
        </Grid>
    </Grid>
</Window>