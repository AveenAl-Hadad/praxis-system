<Window x:Class="Praxis.Client.Views.OnlineBookingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Online-Terminbuchung"
        Height="520"
        Width="520"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Online-Terminbuchung"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="Patient"/>
            <ComboBox x:Name="PatientComboBox"
                      DisplayMemberPath="FullName"
                      SelectedValuePath="Id"
                      Height="32"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="Datum"/>
            <DatePicker x:Name="AppointmentDatePicker"
                        SelectedDateChanged="AppointmentDatePicker_SelectedDateChanged"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,12">
            <TextBlock Text="Dauer (Minuten)"/>
            <ComboBox x:Name="DurationComboBox"
                      SelectionChanged="DurationComboBox_SelectionChanged"
                      Height="32">
                <ComboBoxItem Content="15" IsSelected="True"/>
                <ComboBoxItem Content="30"/>
                <ComboBoxItem Content="60"/>
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="4">
            <TextBlock Text="Freie Termine" Margin="0,0,0,8"/>
            <ListBox x:Name="SlotsListBox" Height="180">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding StringFormat={}{0:dd.MM.yyyy} um {0:HH:mm}}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

        </StackPanel>

        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Content="Abbrechen"
                    Width="110"
                    Margin="0,0,10,0"
                    Click="CancelButton_Click"/>
            <Button Content="Termin buchen"
                    Width="140"
                    Click="BookButton_Click"/>
        </StackPanel>
    </Grid>
</Window>