<Window x:Class="Praxis.Client.Views.AddPatientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Neuer Patient"
        Height="460"
        Width="560"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="16">
        <Border Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Patient anlegen"
                           Style="{StaticResource SectionTitleStyle}"
                           Margin="0,0,0,16"/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Vorname:" Margin="0,0,10,10" VerticalAlignment="Center"/>
                    <TextBox x:Name="FirstNameBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Nachname*:" Margin="0,0,10,10" VerticalAlignment="Center"/>
                    <TextBox x:Name="LastNameBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Geburtsdatum:" Margin="0,0,10,10" VerticalAlignment="Center"/>
                    <DatePicker x:Name="DobPicker" Grid.Row="2" Grid.Column="1" Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="E-Mail:" Margin="0,0,10,10" VerticalAlignment="Center"/>
                    <TextBox x:Name="EmailBox" Grid.Row="3" Grid.Column="1" Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Telefon:" Margin="0,0,10,10" VerticalAlignment="Center"/>
                    <TextBox x:Name="PhoneBox" Grid.Row="4" Grid.Column="1" Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Status:" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <CheckBox x:Name="IsActiveCheck" Grid.Row="5" Grid.Column="1" Content="Aktiv" IsChecked="True"/>
                </Grid>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                    <Button Content="Abbrechen"
                            Width="120"
                            Margin="0,0,10,0"
                            Style="{StaticResource DangerButtonStyle}"
                            Click="Cancel_Click"/>
                    <Button Content="Speichern"
                            Width="120"
                            Style="{StaticResource SuccessButtonStyle}"
                            Click="Save_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>