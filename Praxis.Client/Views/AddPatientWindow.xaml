<Window x:Class="Praxis.Client.Views.AddPatientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Patient anlegen"
        Height="560"
        Width="720"
        MinHeight="520"
        MinWidth="680"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Kopfbereich -->
        <Border Grid.Row="0"
                Style="{StaticResource CardBorderStyle}"
                Margin="0,0,0,12"
                Background="{StaticResource HeaderPanelBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Patient anlegen"
                               Style="{StaticResource SectionTitleStyle}"/>
                    <TextBlock Text="Neue Stammdaten für die Patientenverwaltung erfassen"
                               Foreground="{StaticResource MutedTextBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#EAF6F8"
                        BorderBrush="{StaticResource PrimaryBrush}"
                        BorderThickness="1"
                        CornerRadius="3"
                        Padding="10"
                        HorizontalAlignment="Right"
                        Width="180">
                    <StackPanel>
                        <TextBlock Text="Hinweis"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Pflichtfeld: Nachname"
                                   FontSize="12"
                                   Margin="0,4,0,0"
                                   Foreground="{StaticResource MutedTextBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Formular -->
        <Border Grid.Row="1"
                Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>

                <!-- Linke Hauptform -->
                <Grid Grid.Column="0" Margin="0,0,12,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Text="Vorname"
                               Margin="0,0,12,12"
                               VerticalAlignment="Center"/>
                    <TextBox x:Name="FirstNameBox"
                             Grid.Row="0"
                             Grid.Column="1"
                             Height="32"
                             Margin="0,0,0,12"/>

                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               Text="Nachname *"
                               Margin="0,0,12,12"
                               VerticalAlignment="Center"/>
                    <TextBox x:Name="LastNameBox"
                             Grid.Row="1"
                             Grid.Column="1"
                             Height="32"
                             Margin="0,0,0,12"/>

                    <TextBlock Grid.Row="2"
                               Grid.Column="0"
                               Text="Geburtsdatum"
                               Margin="0,0,12,12"
                               VerticalAlignment="Center"/>
                    <DatePicker x:Name="DobPicker"
                                Grid.Row="2"
                                Grid.Column="1"
                                Height="32"
                                Margin="0,0,0,12"/>

                    <TextBlock Grid.Row="3"
                               Grid.Column="0"
                               Text="E-Mail"
                               Margin="0,0,12,12"
                               VerticalAlignment="Center"/>
                    <TextBox x:Name="EmailBox"
                             Grid.Row="3"
                             Grid.Column="1"
                             Height="32"
                             Margin="0,0,0,12"/>

                    <TextBlock Grid.Row="4"
                               Grid.Column="0"
                               Text="Telefon"
                               Margin="0,0,12,0"
                               VerticalAlignment="Center"/>
                    <TextBox x:Name="PhoneBox"
                             Grid.Row="4"
                             Grid.Column="1"
                             Height="32"/>
                </Grid>

                <!-- Rechte Infospalte -->
                <Border Grid.Column="1"
                        Background="#F3F5F6"
                        BorderBrush="{StaticResource BorderBrushCustom}"
                        BorderThickness="1"
                        CornerRadius="3"
                        Padding="10">
                    <StackPanel>
                        <TextBlock Text="Status"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,10"/>

                        <CheckBox x:Name="IsActiveCheck"
                                  Content="Patient aktiv"
                                  IsChecked="True"
                                  Margin="0,0,0,14"/>

                        <Separator Margin="0,4,0,10"/>

                        <TextBlock Text="Eingabehilfe"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="• Vorname ist optional."
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8"
                                   Foreground="{StaticResource MutedTextBrush}"/>

                        <TextBlock Text="• Nachname sollte immer gesetzt sein."
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8"
                                   Foreground="{StaticResource MutedTextBrush}"/>

                        <TextBlock Text="• Telefon und E-Mail erleichtern Termin- und Erinnerungsverwaltung."
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource MutedTextBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Aktionen -->
        <Border Grid.Row="2"
                Style="{StaticResource CardBorderStyle}"
                Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Patientenstammdaten speichern oder Eingabe abbrechen"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource MutedTextBrush}"/>

                <Button Grid.Column="1"
                        Content="Abbrechen"
                        Width="120"
                        Height="34"
                        Margin="0,0,10,0"
                        Click="Cancel_Click"/>

                <Button Grid.Column="2"
                        Content="Speichern"
                        Width="120"
                        Height="34"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="Save_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>