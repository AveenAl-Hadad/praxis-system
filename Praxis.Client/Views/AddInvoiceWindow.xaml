<Window x:Class="Praxis.Client.Views.AddInvoiceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rechnung erstellen"
        Height="600"
        Width="900"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Neue Rechnung"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,12"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Patient:" VerticalAlignment="Center" Width="80"/>
            <ComboBox x:Name="PatientComboBox" Width="300" DisplayMemberPath="FullName"/>
        </StackPanel>

        <DataGrid x:Name="ItemsGrid"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  Margin="0,0,0,12">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Leistung" Binding="{Binding Description}" Width="*"/>
                <DataGridTextColumn Header="Menge" Binding="{Binding Quantity}" Width="100"/>
                <DataGridTextColumn Header="Einzelpreis" Binding="{Binding UnitPrice}" Width="120"/>
                <DataGridTextColumn Header="Gesamt" Binding="{Binding TotalPrice}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBox x:Name="DescriptionBox" Width="250" Margin="0,0,8,0"/>
            <TextBox x:Name="QuantityBox" Width="100" Margin="0,0,8,0"/>
            <TextBox x:Name="UnitPriceBox" Width="120" Margin="0,0,8,0"/>
            <Button Content="Leistung hinzufügen" Width="160" Click="AddItem_Click"/>
            <Button Content="Entfernen" Width="100" Margin="8,0,0,0" Click="RemoveItem_Click"/>
        </StackPanel>

        <DockPanel Grid.Row="4">
            <TextBlock x:Name="TotalText"
                       Text="Gesamt: 0,00 €"
                       FontSize="18"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       DockPanel.Dock="Left"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Speichern" Width="120" Margin="0,0,8,0" Click="Save_Click"/>
                <Button Content="Abbrechen" Width="120" Click="Cancel_Click"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>