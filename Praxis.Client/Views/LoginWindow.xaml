<Window x:Class="Praxis.Client.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Anmeldung"
        Height="420"
        Width="760"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Linke Infoseite -->
        <Border Grid.Column="0"
                Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource SidebarDarkBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="18"
                Margin="0,0,14,0">
            <StackPanel>
                <TextBlock Text="PRAXIS"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="White"/>
                <TextBlock Text="Verwaltungssystem"
                           FontSize="14"
                           Foreground="#D8E0E5"
                           Margin="0,4,0,20"/>

                <TextBlock Text="Anmeldung"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="White"
                           Margin="0,0,0,10"/>

                <TextBlock Text="• Sicherer Zugriff auf Patienten- und Praxisdaten"
                           TextWrapping="Wrap"
                           Foreground="#E5ECEF"
                           Margin="0,0,0,10"/>

                <TextBlock Text="• Rollen- und Rechteverwaltung für Mitarbeiter"
                           TextWrapping="Wrap"
                           Foreground="#E5ECEF"
                           Margin="0,0,0,10"/>

                <TextBlock Text="• Einheitliche Oberfläche im Praxisstil"
                           TextWrapping="Wrap"
                           Foreground="#E5ECEF"/>
            </StackPanel>
        </Border>

        <!-- Rechte Loginbox -->
        <Border Grid.Column="1"
                Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,16">
                    <TextBlock Text="Benutzeranmeldung"
                               Style="{StaticResource SectionTitleStyle}"/>
                    <TextBlock Text="Bitte Zugangsdaten eingeben"
                               Foreground="{StaticResource MutedTextBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Text="Benutzername"
                               VerticalAlignment="Center"
                               Margin="0,0,12,12"/>
                    <TextBox x:Name="UsernameTextBox"
                             Grid.Row="0"
                             Grid.Column="1"
                             Height="32"
                             Margin="0,0,0,12"/>

                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               Text="Passwort"
                               VerticalAlignment="Center"
                               Margin="0,0,12,12"/>
                    <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,0,12">
                        <PasswordBox x:Name="PasswordBox" Height="32"/>
                        <TextBox x:Name="VisiblePasswordTextBox"
                                 Height="32"
                                 Visibility="Collapsed"/>
                    </Grid>

                    <CheckBox x:Name="ShowPasswordCheckBox"
                              Grid.Row="2"
                              Grid.Column="1"
                              Content="Passwort anzeigen"
                              Margin="0,0,0,12"/>

                    <TextBlock x:Name="ErrorTextBlock"
                               Grid.Row="3"
                               Grid.Column="1"
                               Foreground="{StaticResource DangerBrush}"
                               TextWrapping="Wrap"/>
                </Grid>

                <Grid Grid.Row="2" Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Nur autorisierte Benutzer erhalten Zugriff."
                               VerticalAlignment="Center"
                               Foreground="{StaticResource MutedTextBrush}"/>

                    <Button Grid.Column="1"
                            Width="120"
                            Height="34"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="Login_Click">
                        Anmelden
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>