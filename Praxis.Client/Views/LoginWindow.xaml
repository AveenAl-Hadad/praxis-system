<Window x:Class="Praxis.Client.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login"
        Height="420"
        Width="380"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Border Style="{StaticResource CardBorderStyle}" Padding="20">
            <StackPanel>
                <TextBlock Text="Anmelden"
                           Style="{StaticResource SectionTitleStyle}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <TextBlock Text="Benutzername"/>
                <TextBox x:Name="UsernameTextBox" Margin="0,5,0,12"/>

                <TextBlock Text="Passwort"/>
                <Grid Margin="0,5,0,0">
                    <PasswordBox x:Name="PasswordBox"
                                 Height="34"
                                 PasswordChanged="PasswordBox_PasswordChanged"/>

                    <TextBox x:Name="VisiblePasswordTextBox"
                             Height="34"
                             Visibility="Collapsed"
                             TextChanged="VisiblePasswordTextBox_TextChanged"/>
                </Grid>

                <CheckBox x:Name="ShowPasswordCheckBox"
                          Content="Passwort anzeigen"
                          Margin="0,8,0,16"
                          Checked="ShowPasswordCheckBox_Checked"
                          Unchecked="ShowPasswordCheckBox_Checked"/>

                <Button Content="Login"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="LoginButton_Click"/>

                <Button Content="Passwort vergessen?"
                        Margin="0,10,0,0"
                        Click="ForgotPassword_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>