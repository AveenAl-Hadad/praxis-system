<Window x:Class="Praxis.Client.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login"
        Height="400"
        Width="350"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">

        <StackPanel>

            <TextBlock Text="Anmelden"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="0,0,0,20"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="Benutzername"/>
            <TextBox x:Name="UsernameTextBox"
                     Height="30"
                     Margin="0,5,0,10"/>

            <StackPanel Margin="0,0,0,12">
                <TextBlock Text="Passwort" Margin="0,0,0,5"/>

                <Grid>
                    <PasswordBox x:Name="PasswordBox"
                                 Height="30"
                                 PasswordChanged="PasswordBox_PasswordChanged"/>

                    <TextBox x:Name="VisiblePasswordTextBox"
                             Height="30"
                             Visibility="Collapsed"
                             TextChanged="VisiblePasswordTextBox_TextChanged"/>
                </Grid>

                <CheckBox x:Name="ShowPasswordCheckBox"
                          Content="Passwort anzeigen"
                          Margin="0,8,0,0"
                          Checked="ShowPasswordCheckBox_Checked"
                          Unchecked="ShowPasswordCheckBox_Checked"/>
            </StackPanel>
            
            <Button Content="Login"
                    Height="35"
                    Click="LoginButton_Click"/>
            <Button Content="Passwort vergessen?"
                    HorizontalAlignment="Left"
                    Margin="0,8,0,0"
                    Click="ForgotPassword_Click"/>

        </StackPanel>

    </Grid>
</Window>