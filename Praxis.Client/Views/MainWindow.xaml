<Window x:Class="Praxis.Client.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Praxis System"
        Height="780"
        Width="1400"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="Praxis Verwaltungssystem"
               FontSize="24"
               FontWeight="Bold"
               VerticalAlignment="Center" />

            <StackPanel Grid.Column="1"
                Orientation="Horizontal"
                VerticalAlignment="Center">

                <TextBlock x:Name="LoggedInUserText"
                   VerticalAlignment="Center"
                   Margin="0,0,12,0"
                   FontWeight="SemiBold" />

                <Button x:Name="ThemeToggleButton"
                Width="40"
                Height="36"
                Margin="0,0,10,0"
                Click="ThemeToggle_Click">
                    <TextBlock Text="🌙"
                       FontSize="16"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
                </Button>

                <Button Width="150"
                Margin="0,0,10,0"
                Click="ChangePassword_Click">
                    <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">
                        <TextBlock Text="&#xE72E;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="16"
                           Margin="0,0,8,0" />
                        <TextBlock Text="Passwort ändern" />
                    </StackPanel>
                </Button>

                <Button Width="110"
                Style="{StaticResource DangerButtonStyle}"
                Click="Logout_Click">
                    <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">
                        <TextBlock Text="&#xE8AC;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="16"
                           Margin="0,0,8,0" />
                        <TextBlock Text="Logout" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- TOOLBAR 1 -->
        <Border Grid.Row="1"
        Style="{StaticResource CardBorderStyle}"
        Margin="0,0,0,12">
            <WrapPanel>

                <Button x:Name="AddPatientButton"
                Width="160"
                Height="40"
                Margin="0,0,10,10"
                Style="{StaticResource PrimaryButtonStyle}"
                Click="AddPatient_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="15" Margin="0,0,8,0"/>
                        <TextBlock Text="Patient hinzufügen"/>
                    </StackPanel>
                </Button>

                <Button x:Name="EditPatientButton"
                Width="155"
                Height="40"
                Margin="0,0,10,10"
                Click="EditPatient_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,8,0"/>
                        <TextBlock Text="Patient bearbeiten"/>
                    </StackPanel>
                </Button>

                <Button x:Name="DeletePatientButton"
                Width="145"
                Height="40"
                Margin="0,0,10,10"
                Style="{StaticResource DangerButtonStyle}"
                Click="DeletePatient_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="Patient löschen"/>
                    </StackPanel>
                </Button>

                <Button x:Name="ToggleActiveButton"
                Width="135"
                Height="40"
                Margin="0,0,10,10"
                Click="ToggleActive_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="Aktiv/Inaktiv"/>
                    </StackPanel>
                </Button>

                <Button x:Name="ExportCsvButton"
                Width="120"
                Height="40"
                Margin="0,0,10,10"
                Click="ExportCsv_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#xEDE1;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,8,0"/>
                        <TextBlock Text="CSV Export"/>
                    </StackPanel>
                </Button>

                <Button Width="120"
                Height="40"
                Margin="0,0,10,10"
                Click="Refresh_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,8,0"/>
                        <TextBlock Text="Aktualisieren"/>
                    </StackPanel>
                </Button>

                <TextBox x:Name="SearchBox"
                         Style="{StaticResource SearchTextBoxStyle}"
                         Width="220"
                         Height="32"
                         Margin="20,4,10,10"
                         VerticalAlignment="Center"
                         TextChanged="SearchBox_TextChanged"
                         Tag="Suche..." />

                <CheckBox x:Name="OnlyActiveCheck"
                  Content="Nur aktive Patienten"
                  VerticalAlignment="Center"
                  Margin="0,0,10,10"
                  Checked="OnlyActiveCheck_Changed"
                  Unchecked="OnlyActiveCheck_Changed"/>
            </WrapPanel>
        </Border>

        <!-- TOOLBAR 2 -->
        <Border Grid.Row="2"
        Style="{StaticResource CardBorderStyle}"
        Margin="0,0,0,12">
            <WrapPanel>

                <Button x:Name="AddAppointmentButton"
                Width="145"
                Height="40"
                Margin="0,0,10,10"
                Style="{StaticResource SuccessButtonStyle}"
                Click="OpenAddAppointmentWindow_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE8B5;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,8,0"/>
                        <TextBlock Text="Termin erstellen"/>
                    </StackPanel>
                </Button>

                <Button x:Name="AppointmentsNavigationButton"
                Width="110"
                Height="40"
                Margin="0,0,10,10"
                Click="OpenAppointments_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,8,0"/>
                        <TextBlock Text="Termine"/>
                    </StackPanel>
                </Button>

                <Button x:Name="CalendarButton"
                Width="110"
                Height="40"
                Margin="0,0,10,10"
                Click="OpenCalendar_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,8,0"/>
                        <TextBlock Text="Kalender"/>
                    </StackPanel>
                </Button>

                <Button x:Name="WaitingRoomButton"
                Width="125"
                Height="40"
                Margin="0,0,10,10"
                Click="OpenWaitingRoom_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE8BD;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,8,0"/>
                        <TextBlock Text="Wartezimmer"/>
                    </StackPanel>
                </Button>

                <Button x:Name="InvoiceButton"
                Width="120"
                Height="40"
                Margin="0,0,10,10"
                Style="{StaticResource WarningButtonStyle}"
                Click="OpenInvoices_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE8C7;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,8,0"/>
                        <TextBlock Text="Rechnungen"/>
                    </StackPanel>
                </Button>

                <Button x:Name="PrescriptionButton"
                Width="110"
                Height="40"
                Margin="0,0,10,10"
                Click="OpenPrescriptions_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE91D;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,8,0"/>
                        <TextBlock Text="Rezepte"/>
                    </StackPanel>
                </Button>

                <Button x:Name="DocumentsButton"
                Width="120"
                Height="40"
                Margin="0,0,10,10"
                Click="OpenDocuments_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,8,0"/>
                        <TextBlock Text="Dokumente"/>
                    </StackPanel>
                </Button>

                <Button x:Name="UserManagementButton"
                Width="120"
                Height="40"
                Margin="0,0,10,10"
                Click="UserManagementButton_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,8,0"/>
                        <TextBlock Text="Benutzer"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BackupButton"
                Width="110"
                Height="40"
                Margin="0,0,10,10"
                Click="CreateBackup_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,8,0"/>
                        <TextBlock Text="Backup"/>
                    </StackPanel>
                </Button>

                <Button x:Name="RestoreButton"
                Width="110"
                Height="40"
                Margin="0,0,10,10"
                Click="RestoreBackup_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE72D;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,8,0"/>
                        <TextBlock Text="Restore"/>
                    </StackPanel>
                </Button>

                <Button Width="110"
                Height="40"
                Margin="0,0,10,10"
                Click="OpenAuditLog_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,8,0"/>
                        <TextBlock Text="Audit Log"/>
                    </StackPanel>
                </Button>

                <Button Width="165"
                Height="40"
                Margin="0,0,10,10"
                Click="RefreshDashboard_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,8,0"/>
                        <TextBlock Text="Dashboard neu laden"/>
                    </StackPanel>
                </Button>
                <Button x:Name="OnlineBookingButton"
                        Width="150"
                        Height="36"
                        Margin="0,0,10,10"
                        Click="OnlineBookingButton_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE8A7;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="13"
                                   Margin="0,0,6,0"/>
                        <TextBlock Text="Online Buchung"
                                   FontSize="13"/>
                    </StackPanel>
                </Button>

            </WrapPanel>
        </Border>
        <!-- INHALT -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- DASHBOARD -->
            <UniformGrid Grid.Row="0" Columns="3" Margin="0,0,0,12">
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Patienten gesamt"
                                   Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBlock x:Name="TotalPatientsText"
                                   Text="0"
                                   FontSize="28"
                                   FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Aktive Patienten"
                                   Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBlock x:Name="ActivePatientsText"
                                   Text="0"
                                   FontSize="28"
                                   FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Termine heute"
                                   Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBlock x:Name="TodayAppointmentsText"
                                   Text="0"
                                   FontSize="28"
                                   FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- PATIENTENLISTE -->
            <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
                <DataGrid x:Name="PatientsGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          SelectionChanged="PatientsGrid_SelectionChanged"
                          MouseDoubleClick="PatientsGrid_DoubleClick"
                          KeyDown="PatientsGrid_KeyDown"
                          Sorting="PatientsGrid_Sorting">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"
                                            Binding="{Binding Id}"
                                            SortMemberPath="Id"
                                            Width="70"/>

                        <DataGridTextColumn Header="Vorname"
                                            Binding="{Binding Vorname}"
                                            SortMemberPath="Vorname"
                                            Width="*"/>

                        <DataGridTextColumn Header="Nachname"
                                            Binding="{Binding Nachname}"
                                            SortMemberPath="Nachname"
                                            Width="*"/>

                        <DataGridTextColumn Header="Geburtsdatum"
                                            Binding="{Binding Geburtsdatum, StringFormat=dd.MM.yyyy}"
                                            SortMemberPath="Geburtsdatum"
                                            Width="140"/>

                        <DataGridTextColumn Header="Alter"
                                            Binding="{Binding Alter}"
                                            SortMemberPath="Alter"
                                            Width="80"/>

                        <DataGridTextColumn Header="E-Mail"
                                            Binding="{Binding Email}"
                                            SortMemberPath="Email"
                                            Width="220"/>

                        <DataGridTextColumn Header="Telefon"
                                            Binding="{Binding Telefonnummer}"
                                            SortMemberPath="Telefonnummer"
                                            Width="160"/>

                        <DataGridCheckBoxColumn Header="Aktiv"
                                                Binding="{Binding IsActive}"
                                                SortMemberPath="IsActive"
                                                Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- PAGING -->
            <Grid Grid.Row="2" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="StatusText"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource MutedTextBrush}"/>

                <Button Grid.Column="1"
                        Content="Zurück"
                        Width="90"
                        Margin="0,0,10,0"
                        Click="PrevPage_Click"/>

                <TextBlock x:Name="PageInfoText"
                           Grid.Column="2"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"
                           FontWeight="SemiBold"
                           Text="Seite 1 / 1"/>

                <Button Grid.Column="3"
                        Content="Weiter"
                        Width="90"
                        Click="NextPage_Click"/>
            </Grid>
        </Grid>

        <!-- FOOTER -->
        <TextBlock Grid.Row="4"
                   Margin="0,10,0,0"
                   HorizontalAlignment="Right"
                   Foreground="{StaticResource MutedTextBrush}"
                   Text="F5 = Aktualisieren | Ctrl+N = Neuer Patient | Ctrl+E = CSV Export"/>
    </Grid>
</Window>