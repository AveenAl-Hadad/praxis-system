<Window x:Class="Praxis.Client.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Praxis System"
        Height="820"
        Width="1480"
        MinHeight="760"
        MinWidth="1280"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LINKE SIDEBAR -->
        <Border Grid.Column="0"
                Background="#5D646B"
                BorderBrush="#4F565C"
                BorderThickness="0,0,1,0">
            <Grid Margin="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- LOGO / TITEL -->
                <Border Grid.Row="0"
                        Background="#4E555B"
                        CornerRadius="6"
                        Padding="12"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="PRAXIS"
                                   Foreground="White"
                                   FontSize="22"
                                   FontWeight="Bold"/>
                        <TextBlock Text="Verwaltungssystem"
                                   Foreground="#D7DCE0"
                                   FontSize="12"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- BENUTZER -->
                <Border Grid.Row="1"
                        Background="#6A7279"
                        CornerRadius="6"
                        Padding="10"
                        Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Angemeldet"
                                   Foreground="#DCE3E8"
                                   FontSize="11"/>
                        <TextBlock x:Name="LoggedInUserText"
                                   Foreground="White"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- NAVIGATION -->
                <ScrollViewer Grid.Row="3"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>

                        <TextBlock Text="Navigation"
                                   Foreground="#D7DCE0"
                                   FontSize="11"
                                   Margin="4,0,0,8"/>

                        <Button x:Name="AddPatientButton"
                                Height="42"
                                Margin="0,0,0,8"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="AddPatient_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <TextBlock Text="&#xE77B;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="15"
                                           Margin="0,0,10,0"/>
                                <TextBlock Text="Neuer Patient"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="EditPatientButton"
                                Height="38"
                                Margin="0,0,0,8"
                                Style="{StaticResource SidebarButtonStyle}"
                                Click="EditPatient_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <TextBlock Text="&#xE70F;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="14"
                                           Margin="0,0,10,0"/>
                                <TextBlock Text="Patient bearbeiten"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="DeletePatientButton"
                                Height="38"
                                Margin="0,0,0,8"
                                Style="{StaticResource DangerButtonStyle}"
                                Click="DeletePatient_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <TextBlock Text="&#xE74D;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="14"
                                           Margin="0,0,10,0"/>
                                <TextBlock Text="Patient löschen"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="ToggleActiveButton"
                                Height="38"
                                Margin="0,0,0,8"
                                Click="ToggleActive_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <TextBlock Text="&#xE73E;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="14"
                                           Margin="0,0,10,0"/>
                                <TextBlock Text="Aktiv / Inaktiv"/>
                            </StackPanel>
                        </Button>

                        <Separator Margin="0,10,0,10"/>

                        <Button x:Name="AddAppointmentButton"
                                Height="38"
                                Margin="0,0,0,8"
                                Style="{StaticResource SuccessButtonStyle}"
                                Click="OpenAddAppointmentWindow_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <TextBlock Text="&#xE8B5;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="14"
                                           Margin="0,0,10,0"/>
                                <TextBlock Text="Termin erstellen"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="AppointmentsNavigationButton"
                                Height="38"
                                Margin="0,0,0,8"
                                Click="OpenAppointments_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <TextBlock Text="&#xE787;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="14"
                                           Margin="0,0,10,0"/>
                                <TextBlock Text="Termine"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="CalendarButton"
                                Height="38"
                                Margin="0,0,0,8"
                                Click="OpenCalendar_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <TextBlock Text="&#xE787;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="14"
                                           Margin="0,0,10,0"/>
                                <TextBlock Text="Kalender"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="WaitingRoomButton"
                                Height="38"
                                Margin="0,0,0,8"
                                Click="OpenWaitingRoom_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <TextBlock Text="&#xE8BD;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="14"
                                           Margin="0,0,10,0"/>
                                <TextBlock Text="Wartezimmer"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="InvoiceButton"
                                Height="38"
                                Margin="0,0,0,8"
                                Style="{StaticResource WarningButtonStyle}"
                                Click="OpenInvoices_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <TextBlock Text="&#xE8C7;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="14"
                                           Margin="0,0,10,0"/>
                                <TextBlock Text="Rechnungen"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="PrescriptionButton"
                                Height="38"
                                Margin="0,0,0,8"
                                Click="OpenPrescriptions_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <TextBlock Text="&#xE8C8;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="14"
                                           Margin="0,0,10,0"/>
                                <TextBlock Text="Rezepte"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="DocumentButton"
                                Height="38"
                                Margin="0,0,0,8"
                                Click="OpenDocuments_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <TextBlock Text="&#xE8A5;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="14"
                                           Margin="0,0,10,0"/>
                                <TextBlock Text="Dokumente"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="OnlineBookingButton"
                                Height="38"
                                Margin="0,0,0,8"
                                Click="OnlineBookingButton_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <TextBlock Text="&#xE8A7;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="14"
                                           Margin="0,0,10,0"/>
                                <TextBlock Text="Online Buchung"/>
                            </StackPanel>
                        </Button>

                        <Separator Margin="0,10,0,10"/>

                        <Button x:Name="UserManagementButton"
                                Height="38"
                                Margin="0,0,0,8"
                                Click="UserManagementButton_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <TextBlock Text="&#xE716;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="14"
                                           Margin="0,0,10,0"/>
                                <TextBlock Text="Benutzer"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="BackupButton"
                                Height="38"
                                Margin="0,0,0,8"
                                Click="CreateBackup_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <TextBlock Text="&#xE74E;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="14"
                                           Margin="0,0,10,0"/>
                                <TextBlock Text="Backup"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="RestoreButton"
                                Height="38"
                                Margin="0,0,0,8"
                                Click="RestoreBackup_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <TextBlock Text="&#xE72D;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="14"
                                           Margin="0,0,10,0"/>
                                <TextBlock Text="Restore"/>
                            </StackPanel>
                        </Button>

                        <Button Height="38"
                                Margin="0,0,0,8"
                                Click="OpenAuditLog_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <TextBlock Text="&#xE9D9;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="14"
                                           Margin="0,0,10,0"/>
                                <TextBlock Text="Audit Log"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </ScrollViewer>

                <!-- UNTERE AKTIONEN -->
                <StackPanel Grid.Row="4" Margin="0,12,0,0">
                    <Button x:Name="ThemeToggleButton"
                            Height="36"
                            Margin="0,0,0,8"
                            Click="ThemeToggle_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="🌙" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="Design wechseln"/>
                        </StackPanel>
                    </Button>

                    <Button Height="36"
                            Margin="0,0,0,8"
                            Click="ChangePassword_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="&#xE72E;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14"
                                       Margin="0,0,8,0"/>
                            <TextBlock Text="Passwort ändern"/>
                        </StackPanel>
                    </Button>

                    <Button Height="36"
                            Style="{StaticResource DangerButtonStyle}"
                            Click="Logout_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="&#xE8AC;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14"
                                       Margin="0,0,8,0"/>
                            <TextBlock Text="Logout"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- RECHTE HAUPTFLÄCHE -->
        <Grid Grid.Column="1" Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- OBERER KONTEXTBEREICH -->
            <Border Grid.Row="0"
                    Background="#F5F6F7"
                    BorderBrush="#C9CDD2"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="14"
                    Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="340"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Patientenverwaltung"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TitleTextBrush}"/>
                        <TextBlock Text="Zentrale Übersicht für Patienten, Termine und Praxisaktionen"
                                   FontSize="13"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                HorizontalAlignment="Right">
                        <TextBox x:Name="SearchBox"
                                 Width="320"
                                 Height="34"
                                 Style="{StaticResource SearchTextBoxStyle}"
                                 TextChanged="SearchBox_TextChanged"
                                 Tag="Patient suchen..." />
                        <CheckBox x:Name="OnlyActiveCheck"
                                  Content="Nur aktive Patienten"
                                  Margin="2,10,0,0"
                                  Checked="OnlyActiveCheck_Changed"
                                  Unchecked="OnlyActiveCheck_Changed"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- DASHBOARD-KACHELN -->
            <UniformGrid Grid.Row="1"
             Columns="4"
             Margin="0,0,0,12">
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="Patienten gesamt"
                       FontSize="12"
                       Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBlock x:Name="TotalPatientsText"
                       Text="0"
                       FontSize="28"
                       FontWeight="Bold"
                       Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="Aktive Patienten"
                       FontSize="12"
                       Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBlock x:Name="ActivePatientsText"
                       Text="0"
                       FontSize="28"
                       FontWeight="Bold"
                       Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="Termine heute"
                       FontSize="12"
                       Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBlock x:Name="TodayAppointmentsText"
                       Text="0"
                       FontSize="28"
                       FontWeight="Bold"
                       Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Aktion"
                       FontSize="12"
                       Foreground="{StaticResource MutedTextBrush}"/>
                        <Button Width="150"
                    Height="32"
                    Margin="0,8,0,0"
                    Click="RefreshDashboard_Click">
                            Dashboard laden
                        </Button>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- MITTLERER ARBEITSBEREICH -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="285"/>
                </Grid.ColumnDefinitions>

                <!-- PATIENTENLISTE -->
                <Border Grid.Column="0"
            Style="{StaticResource CardBorderStyle}"
            Margin="0,0,12,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- LISTENKOPF -->
                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Patientenliste"
                               FontSize="16"
                               FontWeight="SemiBold"/>
                                <TextBlock Text="Übersicht, Auswahl und Schnellzugriff auf Patientendaten"
                               FontSize="12"
                               Foreground="{StaticResource MutedTextBrush}"
                               Margin="0,2,0,0"/>
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Width="120"
                                    Height="32"
                                    Margin="0,0,8,0"
                                    Click="Refresh_Click">
                                Aktualisieren
                            </Button>

                            <Button x:Name="ExportCsvButton"
                                    Grid.Column="2"
                                    Width="110"
                                    Height="32"
                                    Click="ExportCsv_Click">
                                CSV Export
                            </Button>
                        </Grid>

                        <!-- TABELLE -->
                        <Border Grid.Row="1"
                    BorderBrush="{StaticResource BorderBrushCustom}"
                    BorderThickness="1"
                    Background="White">
                            <DataGrid Grid.Row="1"
                          x:Name="PatientsGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          SelectionChanged="PatientsGrid_SelectionChanged"
                          MouseDoubleClick="PatientsGrid_DoubleClick"
                          KeyDown="PatientsGrid_KeyDown"
                          Sorting="PatientsGrid_Sorting"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          RowHeaderWidth="0"
                          SelectionMode="Single"
                          SelectionUnit="FullRow">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID"
                                            Binding="{Binding Id}"
                                            SortMemberPath="Id"
                                            Width="60"/>

                                    <DataGridTextColumn Header="Vorname"
                                            Binding="{Binding Vorname}"
                                            SortMemberPath="Vorname"
                                            Width="*"/>

                                    <DataGridTextColumn Header="Nachname"
                                            Binding="{Binding Nachname}"
                                            SortMemberPath="Nachname"
                                            Width="*"/>

                                    <DataGridTextColumn Header="Geburtsdatum"
                                            Binding="{Binding Geburtsdatum, StringFormat=dd.MM.yyyy}"
                                            SortMemberPath="Geburtsdatum"
                                            Width="120"/>

                                    <DataGridTextColumn Header="Alter"
                                            Binding="{Binding Alter}"
                                            SortMemberPath="Alter"
                                            Width="60"/>

                                    <DataGridTextColumn Header="Telefon"
                                            Binding="{Binding Telefonnummer}"
                                            SortMemberPath="Telefonnummer"
                                            Width="135"/>

                                    <DataGridTextColumn Header="E-Mail"
                                            Binding="{Binding Email}"
                                            SortMemberPath="Email"
                                            Width="190"/>

                                    <DataGridCheckBoxColumn Header="Aktiv"
                                                Binding="{Binding IsActive}"
                                                SortMemberPath="IsActive"
                                                Width="70"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </Border>

                <!-- RECHTE INFO-/AKTIONSSPALTE -->
                <StackPanel Grid.Column="1">

                    <!-- SCHNELLAKTIONEN -->
                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Schnellaktionen"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Margin="0,0,0,10"/>

                            <Button Height="34"
                        Margin="0,0,0,8"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="AddPatient_Click">
                                Patient anlegen
                            </Button>

                            <Button Height="34"
                        Margin="0,0,0,8"
                        Style="{StaticResource SuccessButtonStyle}"
                        Click="OpenAddAppointmentWindow_Click">
                                Termin anlegen
                            </Button>

                            <Button Height="34"
                        Margin="0,0,0,8"
                        Click="EditPatient_Click">
                                Patient bearbeiten
                            </Button>

                            <Button Height="34"
                        Margin="0,0,0,8"
                        Click="OpenDocuments_Click">
                                Dokumente öffnen
                            </Button>

                            <Button Height="34"
                        Margin="0,0,0,8"
                        Style="{StaticResource WarningButtonStyle}"
                        Click="OpenInvoices_Click">
                                Rechnungen öffnen
                            </Button>

                            <Button Height="34"
                        Click="OpenWaitingRoom_Click">
                                Wartezimmer öffnen
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- PATIENTENINFO -->
                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Patienten-Kurzinfo"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Margin="0,0,0,10"/>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="95"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Name:"
                               Foreground="{StaticResource MutedTextBrush}"/>
                                <TextBlock Grid.Column="1"
                               x:Name="SelectedPatientNameText"
                               Text="Kein Patient gewählt"
                               FontWeight="SemiBold"/>
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="95"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Geboren:"
                               Foreground="{StaticResource MutedTextBrush}"/>
                                <TextBlock Grid.Column="1"
                               x:Name="SelectedPatientBirthDateText"
                               Text="-" />
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="95"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Telefon:"
                               Foreground="{StaticResource MutedTextBrush}"/>
                                <TextBlock Grid.Column="1"
                               x:Name="SelectedPatientPhoneText"
                               Text="-" />
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="95"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="E-Mail:"
                               Foreground="{StaticResource MutedTextBrush}"/>
                                <TextBlock Grid.Column="1"
                               x:Name="SelectedPatientEmailText"
                               Text="-"
                               TextWrapping="Wrap"/>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="95"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Status:"
                               Foreground="{StaticResource MutedTextBrush}"/>
                                <TextBlock Grid.Column="1"
                               x:Name="SelectedPatientStatusText"
                               Text="-" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- HINWEISE -->
                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Hinweise"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Margin="0,0,0,10"/>

                            <TextBlock Text="• Doppelklick auf einen Patienten öffnet die Details."
                           TextWrapping="Wrap"
                           Margin="0,0,0,8"
                           Foreground="{StaticResource MutedTextBrush}"/>

                            <TextBlock Text="• Mit Ctrl+N kann schnell ein neuer Patient angelegt werden."
                           TextWrapping="Wrap"
                           Margin="0,0,0,8"
                           Foreground="{StaticResource MutedTextBrush}"/>

                            <TextBlock Text="• Mit F5 wird die Übersicht aktualisiert."
                           TextWrapping="Wrap"
                           Foreground="{StaticResource MutedTextBrush}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- PAGING -->
            <Grid Grid.Row="3" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="StatusText"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource MutedTextBrush}"/>

                <Button Grid.Column="1"
                        Content="Zurück"
                        Width="90"
                        Margin="0,0,10,0"
                        Click="PrevPage_Click"/>

                <TextBlock x:Name="PageInfoText"
                           Grid.Column="2"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"
                           FontWeight="SemiBold"
                           Text="Seite 1 / 1"/>

                <Button Grid.Column="3"
                        Content="Weiter"
                        Width="90"
                        Click="NextPage_Click"/>
            </Grid>
        </Grid>
    </Grid>
</Window>