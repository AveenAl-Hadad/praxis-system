<Window x:Class="Praxis.Client.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PraxisSystem"
        Height="700"
        Width="1150"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Kopfzeile -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Patientenliste"
                       FontSize="28"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>

            <TextBlock x:Name="LoggedInUserText"
                       Grid.Column="1"
                       Margin="0,0,12,0"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"
                       FontSize="14"/>
            <Button Content="Passwort ändern"
                    Width="140"
                    Height="32"
                    Margin="0,0,10,0"
                    Click="ChangePassword_Click"/>

            <Button Grid.Column="2"
                    Content="Abmelden"
                    Width="110"
                    Height="32"
                    Click="Logout_Click"/>
        </Grid>

        <!-- Suche / Filter -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Height="32">
                <TextBox x:Name="SearchBox"
                         VerticalContentAlignment="Center"
                         Padding="8,0,8,0"
                         TextChanged="SearchBox_TextChanged"/>

                <TextBlock Text="Suche..."
                           Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="Gray"
                           IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <CheckBox x:Name="OnlyActiveCheck"
                      Grid.Column="1"
                      Margin="12,0,0,0"
                      VerticalAlignment="Center"
                      Content="Nur aktive"
                      IsChecked="True"
                      Checked="OnlyActiveCheck_Changed"
                      Unchecked="OnlyActiveCheck_Changed"/>
        </Grid>

        <!-- Aktionsbereich Zeile 1 -->
        <WrapPanel Grid.Row="2" Margin="0,0,0,8" ItemHeight="80">

            <GroupBox Header="Patient" Margin="0,0,10,8" Padding="8,6">
                <WrapPanel>
                    <Button Content="Neu"
                            Width="90"
                            Height="30"
                            Margin="0,0,8,0"
                            Click="AddPatient_Click"/>

                    <Button Content="Bearbeiten"
                            Width="90"
                            Height="30"
                            Margin="0,0,8,0"
                            Click="EditPatient_Click"/>

                    <Button Content="Löschen"
                            Width="90"
                            Height="30"
                            Click="DeletePatient_Click"/>
                </WrapPanel>
            </GroupBox>

            <GroupBox Header="Status" Margin="0,0,10,8" Padding="8,6">
                <WrapPanel>
                    <Button Content="Toggle"
                            Width="90"
                            Height="30"
                            Click="ToggleActive_Click"/>
                </WrapPanel>
            </GroupBox>

            <GroupBox Header="Export" Margin="0,0,10,8" Padding="8,6">
                <WrapPanel>
                    <Button Content="CSV"
                            Width="90"
                            Height="30"
                            Click="ExportCsv_Click"/>
                </WrapPanel>
            </GroupBox>

            <GroupBox Header="Ansicht" Margin="0,0,10,8" Padding="8,6">
                <WrapPanel>
                    <Button Content="Refresh"
                            Width="90"
                            Height="30"
                            Click="Refresh_Click"/>
                </WrapPanel>
            </GroupBox>

            <GroupBox Header="Termin" Margin="0,0,10,8" Padding="8,6">
                <WrapPanel>
                    <Button Content="Termin anlegen"
                            Width="140"
                            Height="30"
                            Click="OpenAddAppointmentWindow_Click"/>
                </WrapPanel>
            </GroupBox>
        </WrapPanel>
        

        <!-- Aktionsbereich Zeile 2 -->
        <WrapPanel Grid.Row="3" Margin="0,0,0,10" VerticalAlignment="Top">
            <Button Content="Termine"
                    Width="120"
                    Height="32"
                    Margin="0,0,10,0"
                    Click="OpenAppointments_Click"/>

            <Button Content="Kalender"
                    Width="120"
                    Height="32"
                    Margin="0,0,10,0"
                    Click="OpenCalendar_Click"/>

            <Button Content="Wartezimmer"
                    Width="120"
                    Height="32"
                    Margin="0,0,10,0"
                    Click="OpenWaitingRoom_Click"/>
            <Button Content="Rechnungen"
                     Width="120"
                     Height="32"
                     Margin="0,0,10,0"
                     Click="OpenInvoices_Click"/>
            <Button Content="Rezepte"
                    Width="120"
                    Height="32"
                    Margin="0,0,10,0"
                    Click="OpenPrescriptions_Click"/>
            <Button Content="Dokumente"
                    Width="120"
                    Click="OpenDocuments_Click"/>

            <Button x:Name="UserManagementButton"
                    Content="Benutzerverwaltung"
                    Width="160"
                    Height="32"
                    Click="UserManagementButton_Click"/>
        </WrapPanel>

        <!-- Datagrid -->
        <Grid Grid.Row="3" Margin="0,50,0,0">
            <DataGrid x:Name="PatientsGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      MouseDoubleClick="PatientsGrid_DoubleClick"
                      KeyDown="PatientsGrid_KeyDown"
                      Sorting="PatientsGrid_Sorting">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70"/>
                    <DataGridTextColumn Header="Nachname" Binding="{Binding Nachname}" Width="2*"/>
                    <DataGridTextColumn Header="Vorname" Binding="{Binding Vorname}" Width="2*"/>
                    <DataGridTextColumn Header="Geburt" Binding="{Binding Geburtsdatum, StringFormat=d}" Width="120"/>
                    <DataGridTextColumn Header="Alter" Binding="{Binding Alter}" Width="80"/>
                    <DataGridTextColumn Header="E-Mail" Binding="{Binding Email}" Width="2*"/>
                    <DataGridTextColumn Header="Telefon" Binding="{Binding Telefonnummer}" Width="160"/>

                    <DataGridTemplateColumn Header="Aktiv" Width="70">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsActive}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          IsHitTestVisible="False"
                                          Focusable="False"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Pagination -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="Zurück"
                    Width="100"
                    Height="30"
                    Margin="0,0,10,0"
                    Click="PrevPage_Click"/>

            <TextBlock x:Name="PageInfoText"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"
                       FontWeight="SemiBold"/>

            <Button Content="Weiter"
                    Width="100"
                    Height="30"
                    Click="NextPage_Click"/>
        </StackPanel>

        <!-- Status -->
        <TextBlock Grid.Row="5"
                   x:Name="StatusText"
                   Margin="0,10,0,0"
                   Foreground="Gray"/>
    </Grid>
</Window>