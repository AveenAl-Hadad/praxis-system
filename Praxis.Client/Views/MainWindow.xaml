<Window x:Class="Praxis.Client.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Praxissoftware"
        Height="800"
        Width="1200"
        MinHeight="760"
        MinWidth="1280"
        Background="{DynamicResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="82"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrushCustom}"
                BorderThickness="0,0,0,1"
                Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="340"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                    <TextBlock Text="Gehe zu..."
                               Margin="2,0,0,4"
                               Foreground="{DynamicResource MutedTextBrush}"/>
                    <TextBox Width="260"
                             Height="32"
                             Style="{StaticResource SearchTextBoxStyle}"
                             Tag="Gehe zu..." />
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock Text="Praxissoftware" Style="{StaticResource SectionTitleStyle}"/>
                    <TextBlock Text="Modulare Navigation wie in der Referenzansicht"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{DynamicResource PrimaryBrush}"
                            Width="34"
                            Height="34"
                            CornerRadius="17"
                            Margin="0,0,10,0">
                        <TextBlock x:Name="UserInitialText"
                                   Text="U"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"
                                   Margin="0,7,0,0"/>
                    </Border>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="LoggedInUserText" Text="Benutzername" FontWeight="SemiBold"/>
                        <TextBlock x:Name="LoggedInStatusText" Text="Angemeldet" Foreground="{DynamicResource MutedTextBrush}" FontSize="11"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- LINKE SIDEBAR -->
        <Border Grid.Row="1"
                Grid.Column="0"
                Background="{DynamicResource SidebarDarkBrush}"
                BorderBrush="{DynamicResource BorderBrushCustom}"
                BorderThickness="0,0,1,0"
                Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Navigation"
                           Foreground="White"
                           FontWeight="Bold"
                           FontSize="15"
                           Margin="4,2,0,12"/>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="DynamicSidebarPanel" Margin="4"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- RECHTE SEITE -->
        <Grid Grid.Row="1" Grid.Column="1" x:Name="ContentArea" Margin="14">
            <ContentControl x:Name="MainContentControl"/>
        </Grid>

        <!-- BOTTOM NAV -->
        <Border Grid.Row="2"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Background="#383E44"
                BorderBrush="{DynamicResource BorderBrushCustom}"
                BorderThickness="0,1,0,0"
                Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <UniformGrid Columns="8" Rows="1" Margin="0,0,12,0">
                    <Button x:Name="BottomPatientsButton" Content="Patienten" Style="{StaticResource BottomNavButtonStyle}" Margin="6,0" Click="BottomPatients_Click"/>
                    <Button Content="Labor" Style="{StaticResource BottomNavButtonStyle}" Margin="6,0" Click="BottomLabor_Click"/>
                    <Button Content="Abrechnung" Style="{StaticResource BottomNavButtonStyle}" Margin="6,0" Click="BottomBilling_Click"/>
                    <Button Content="Auswertungen" Style="{StaticResource BottomNavButtonStyle}" Margin="6,0" Click="BottomReports_Click"/>
                    <Button Content="Nachrichten" Style="{StaticResource BottomNavButtonStyle}" Margin="6,0" Click="BottomMessages_Click"/>
                    <Button Content="Kataloge" Style="{StaticResource BottomNavButtonStyle}" Margin="6,0" Click="BottomCatalogs_Click"/>
                    <Button Content="Einrichtung" Style="{StaticResource BottomNavButtonStyle}" Margin="6,0" Click="BottomSetup_Click"/>
                    <Button Content="Einstellungen" Style="{StaticResource BottomNavButtonStyle}" Margin="6,0" Click="BottomSettings_Click"/>
                </UniformGrid>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrushCustom}" BorderThickness="1" CornerRadius="6" Padding="10,6" Margin="0,0,8,0">
                        <TextBlock Text="2" FontWeight="Bold"/>
                    </Border>
                    <Border Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrushCustom}" BorderThickness="1" CornerRadius="6" Padding="10,6" Margin="0,0,8,0">
                        <TextBlock Text="1" FontWeight="Bold"/>
                    </Border>
                    <Border Background="{DynamicResource SuccessBrush}" CornerRadius="16" Width="32" Height="32">
                        <TextBlock Text="✓" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" Margin="0,6,0,0"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>