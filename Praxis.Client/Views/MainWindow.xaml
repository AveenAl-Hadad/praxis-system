<Window x:Class="Praxis.Client.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PraxisSystem"
        Height="850"
        Width="1300"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Kopf -->
        <Border Grid.Row="0"
                Style="{StaticResource CardBorderStyle}"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Praxisverwaltung"
                               Style="{StaticResource SectionTitleStyle}"
                               FontSize="30"/>
                    <TextBlock Text="Patientenübersicht und Verwaltung"
                               FontSize="14"
                               Foreground="{StaticResource MutedTextBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="LoggedInUserText"
                               Margin="0,0,16,0"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               FontSize="14"/>

                    <Button Content="Passwort ändern"
                            Width="140"
                            Margin="0,0,10,0"
                            Style="{StaticResource WarningButtonStyle}"
                            Click="ChangePassword_Click"/>

                    <Button Content="Abmelden"
                            Width="110"
                            Style="{StaticResource DangerButtonStyle}"
                            Click="Logout_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Suche + Toolbar -->
        <Border Grid.Row="1"
                Style="{StaticResource CardBorderStyle}"
                Margin="0,0,0,12">
            <DockPanel LastChildFill="False">

                <StackPanel DockPanel.Dock="Left"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <Grid Width="320"
                          Height="34"
                          Margin="0,0,12,0">
                        <TextBox x:Name="SearchBox"
                                 VerticalContentAlignment="Center"
                                 TextChanged="SearchBox_TextChanged"/>

                        <TextBlock Text="Patient suchen..."
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="Gray"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <CheckBox x:Name="OnlyActiveCheck"
                              Margin="0,0,16,0"
                              Content="Nur aktive"
                              IsChecked="True"
                              Checked="OnlyActiveCheck_Changed"
                              Unchecked="OnlyActiveCheck_Changed"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal">

                    <Button Style="{StaticResource SuccessButtonStyle}"
                            Width="38"
                            Height="38"
                            Margin="0,0,8,0"
                            ToolTip="Patient hinzufügen"
                            Click="AddPatient_Click">
                        <TextBlock Text="+"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Button>

                    <Button Style="{StaticResource PrimaryButtonStyle}"
                            Width="38"
                            Height="38"
                            Margin="0,0,8,0"
                            ToolTip="Patient bearbeiten"
                            Click="EditPatient_Click">
                        <TextBlock Text="✎"
                                   FontSize="16"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Button>

                    <Button Style="{StaticResource DangerButtonStyle}"
                            Width="38"
                            Height="38"
                            Margin="0,0,8,0"
                            ToolTip="Patient löschen"
                            Click="DeletePatient_Click">
                        <TextBlock Text="X"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Button>

                    <Button Style="{StaticResource WarningButtonStyle}"
                            Width="38"
                            Height="38"
                            Margin="0,0,8,0"
                            ToolTip="Aktiv/Inaktiv umschalten"
                            Click="ToggleActive_Click">
                        <TextBlock Text="✓"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Button>

                    <Button Style="{StaticResource PrimaryButtonStyle}"
                            Width="38"
                            Height="38"
                            Margin="0,0,8,0"
                            ToolTip="Liste aktualisieren"
                            Click="Refresh_Click">
                        <TextBlock Text="↻"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Button>

                    <Button Style="{StaticResource PrimaryButtonStyle}"
                            Width="38"
                            Height="38"
                            Margin="0,0,8,0"
                            ToolTip="CSV exportieren"
                            Click="ExportCsv_Click">
                        <TextBlock Text="⇩"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Button>

                    <Button Style="{StaticResource PrimaryButtonStyle}"
                            Width="38"
                            Height="38"
                            Margin="0,0,8,0"
                            ToolTip="Termin anlegen"
                            Click="OpenAddAppointmentWindow_Click">
                        <TextBlock Text="T"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Button>

                    <Button Style="{StaticResource PrimaryButtonStyle}"
                            Width="90"
                            Margin="0,0,8,0"
                            ToolTip="Rechnungen öffnen"
                            Click="OpenInvoices_Click"
                            Content="Rechnung"/>

                    <Button Style="{StaticResource PrimaryButtonStyle}"
                            Width="80"
                            Margin="0,0,8,0"
                            ToolTip="Rezepte öffnen"
                            Click="OpenPrescriptions_Click"
                            Content="Rezept"/>

                    <Button Style="{StaticResource PrimaryButtonStyle}"
                            Width="95"
                            Margin="0,0,8,0"
                            ToolTip="Dokumente öffnen"
                            Click="OpenDocuments_Click"
                            Content="Dokument"/>

                    <Button x:Name="UserManagementButton"
                            Style="{StaticResource WarningButtonStyle}"
                            Width="120"
                            ToolTip="Benutzerverwaltung"
                            Click="UserManagementButton_Click"
                            Content="Benutzer"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Statistik -->
        <Expander Grid.Row="2"
                  Header="Dashboard und Statistik"
                  IsExpanded="False"
                  Margin="0,0,0,12">
            <StackPanel Margin="12">

                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="8">
                            <TextBlock Text="Patienten" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TotalPatientsText"
                                       Text="0"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="8">
                            <TextBlock Text="Termine" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TotalAppointmentsText"
                                       Text="0"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="8">
                            <TextBlock Text="Rechnungen" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TotalInvoicesText"
                                       Text="0"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="3" Margin="8">
                            <TextBlock Text="Rezepte" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TotalPrescriptionsText"
                                       Text="0"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4" Margin="8">
                            <TextBlock Text="Gesamtumsatz" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TotalRevenueText"
                                       Text="0,00 €"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="8">
                            <TextBlock Text="Termine diesen Monat" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="CurrentMonthAppointmentsText"
                                       Text="0"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="8">
                            <TextBlock Text="Rechnungen diesen Monat" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="CurrentMonthInvoicesText"
                                       Text="0"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="8">
                            <TextBlock Text="Umsatz diesen Monat" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="CurrentMonthRevenueText"
                                       Text="0,00 €"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <Button Content="Dashboard aktualisieren"
                                Width="160"
                                Margin="0,0,0,10"
                                HorizontalAlignment="Left"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="RefreshDashboard_Click"/>

                        <TextBlock Text="Termine" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ProgressBar x:Name="AppointmentsChartBar"
                                     Height="18"
                                     Minimum="0"
                                     Maximum="100"
                                     Value="0"/>
                        <TextBlock x:Name="AppointmentsChartLabel"
                                   Text="0 Termine"
                                   Margin="0,4,0,10"/>

                        <TextBlock Text="Rechnungen" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ProgressBar x:Name="InvoicesChartBar"
                                     Height="18"
                                     Minimum="0"
                                     Maximum="100"
                                     Value="0"/>
                        <TextBlock x:Name="InvoicesChartLabel"
                                   Text="0 Rechnungen"
                                   Margin="0,4,0,10"/>

                        <TextBlock Text="Umsatz" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ProgressBar x:Name="RevenueChartBar"
                                     Height="18"
                                     Minimum="0"
                                     Maximum="100"
                                     Value="0"/>
                        <TextBlock x:Name="RevenueChartLabel"
                                   Text="0,00 € Umsatz"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Expander>

        <!-- Patientenliste -->
        <Border Grid.Row="3"
                Style="{StaticResource CardBorderStyle}"
                Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Patientenliste"
                           Style="{StaticResource SectionTitleStyle}"
                           Margin="0,0,0,10"/>

                <DataGrid x:Name="PatientsGrid"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          MouseDoubleClick="PatientsGrid_DoubleClick"
                          KeyDown="PatientsGrid_KeyDown"
                          Sorting="PatientsGrid_Sorting">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70"/>
                        <DataGridTextColumn Header="Nachname" Binding="{Binding Nachname}" Width="2*"/>
                        <DataGridTextColumn Header="Vorname" Binding="{Binding Vorname}" Width="2*"/>
                        <DataGridTextColumn Header="Geburtsdatum" Binding="{Binding Geburtsdatum, StringFormat=dd.MM.yyyy}" Width="130"/>
                        <DataGridTextColumn Header="Alter" Binding="{Binding Alter}" Width="80"/>
                        <DataGridTextColumn Header="E-Mail" Binding="{Binding Email}" Width="2*"/>
                        <DataGridTextColumn Header="Telefon" Binding="{Binding Telefonnummer}" Width="160"/>

                        <DataGridTemplateColumn Header="Aktiv" Width="70">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsActive}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              IsHitTestVisible="False"
                                              Focusable="False"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Untere Navigation -->
        <WrapPanel Grid.Row="4" Margin="0,0,0,10">
            <Button Content="Termine"
                    Width="120"
                    Margin="0,0,10,0"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="OpenAppointments_Click"/>

            <Button Content="Kalender"
                    Width="120"
                    Margin="0,0,10,0"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="OpenCalendar_Click"/>

            <Button Content="Wartezimmer"
                    Width="120"
                    Margin="0,0,10,0"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="OpenWaitingRoom_Click"/>
        </WrapPanel>

        <!-- Pagination -->
        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="StatusText"
                       Grid.Column="0"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource MutedTextBrush}"/>

            <Button Content="Zurück"
                    Grid.Column="1"
                    Width="100"
                    Margin="0,0,10,0"
                    Style="{StaticResource WarningButtonStyle}"
                    Click="PrevPage_Click"/>

            <TextBlock x:Name="PageInfoText"
                       Grid.Column="2"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"
                       FontWeight="SemiBold"/>

            <Button Content="Weiter"
                    Grid.Column="3"
                    Width="100"
                    Style="{StaticResource WarningButtonStyle}"
                    Click="NextPage_Click"/>
        </Grid>
    </Grid>
</Window>