<Window x:Class="Praxis.Client.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PraxisSystem"
        Height="650"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,10">
            <StackPanel Orientation="Vertical">

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Patientenliste"
                               FontSize="18"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">

                        <Grid Width="260" Height="32" Margin="0,0,12,0">
                            <TextBox x:Name="SearchBox"
                                     VerticalContentAlignment="Center"
                                     TextChanged="SearchBox_TextChanged"/>

                            <TextBlock Text="Suche..."
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="Gray"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <CheckBox x:Name="OnlyActiveCheck"
                                  Content="Nur aktive"
                                  VerticalAlignment="Center"
                                  IsChecked="True"
                                  Checked="OnlyActiveCheck_Changed"
                                  Unchecked="OnlyActiveCheck_Changed"/>
                    </StackPanel>
                </Grid>

                <WrapPanel>
                    <GroupBox Header="Patient" Margin="0,0,10,8" Padding="8,6">
                        <WrapPanel>
                            <Button Content="Neu"
                                    Width="90"
                                    Height="30"
                                    Margin="0,0,8,0"
                                    Click="AddPatient_Click"
                                    ToolTip="Neuen Patienten anlegen (Strg+N)"/>

                            <Button Content="Bearbeiten"
                                    Width="90"
                                    Height="30"
                                    Margin="0,0,8,0"
                                    Click="EditPatient_Click"
                                    ToolTip="Ausgewählten Patienten bearbeiten"/>

                            <Button Content="Löschen"
                                    Width="90"
                                    Height="30"
                                    Click="DeletePatient_Click"
                                    ToolTip="Ausgewählten Patienten löschen (Entf)"/>
                        </WrapPanel>
                    </GroupBox>

                    <GroupBox Header="Status" Margin="0,0,10,8" Padding="8,6">
                        <WrapPanel>
                            <Button Content="Toggle"
                                    Width="90"
                                    Height="30"
                                    Click="ToggleActive_Click"
                                    ToolTip="Aktiv/Inaktiv umschalten"/>
                        </WrapPanel>
                    </GroupBox>

                    <GroupBox Header="Export" Margin="0,0,10,8" Padding="8,6">
                        <WrapPanel>
                            <Button Content="CSV"
                                    Width="90"
                                    Height="30"
                                    Click="ExportCsv_Click"
                                    ToolTip="Aktuelle Liste als CSV exportieren (Strg+E)"/>
                        </WrapPanel>
                    </GroupBox>

                    <GroupBox Header="Ansicht" Margin="0,0,10,8" Padding="8,6">
                        <WrapPanel>
                            <Button Content="Refresh"
                                    Width="90"
                                    Height="30"
                                    Click="Refresh_Click"
                                    ToolTip="Neu laden (F5)"/>
                        </WrapPanel>
                    </GroupBox>

                    <GroupBox Header="Termin" Margin="0,0,10,8" Padding="8,6">
                        <WrapPanel>
                            <Button Content="Termin anlegen"
                                    Width="140"
                                    Height="30"
                                    Click="OpenAddAppointmentWindow_Click"/>
                        </WrapPanel>
                    </GroupBox>

                    <Button Content="Termine"
                            Width="120"
                            Height="30"
                            Margin="5"
                            Click="OpenAppointments_Click"/>

                    <Button Content="Kalender"
                            Width="120"
                            Height="30"
                            Margin="5"
                            Click="OpenCalendar_Click"/>

                    <Button Content="Wartezimmer"
                            Width="120"
                            Height="30"
                            Margin="5"
                            Click="OpenWaitingRoom_Click"/>

                    <Button x:Name="UserManagementButton"
                            Content="Benutzerverwaltung"
                            Width="150"
                            Height="30"
                            Margin="5"
                           />
                </WrapPanel>

            </StackPanel>
        </DockPanel>

        <DataGrid Grid.Row="1"
                  x:Name="PatientsGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="False"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  MouseDoubleClick="PatientsGrid_DoubleClick"
                  KeyDown="PatientsGrid_KeyDown"
                  CanUserSortColumns="True"
                  Sorting="PatientsGrid_Sorting">

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="White"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                            <Setter Property="Background" Value="#FFF8D7DA"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                            <Setter Property="Background" Value="#FFE6FFED"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" SortMemberPath="Id" Width="70" IsReadOnly="True"/>
                <DataGridTextColumn Header="Nachname" Binding="{Binding Nachname}" SortMemberPath="Nachname" Width="2*" IsReadOnly="True"/>
                <DataGridTextColumn Header="Vorname" Binding="{Binding Vorname}" SortMemberPath="Vorname" Width="2*" IsReadOnly="True"/>
                <DataGridTextColumn Header="Geburt" Binding="{Binding Geburtsdatum, StringFormat=d}" SortMemberPath="Geburtsdatum" Width="120" IsReadOnly="True"/>
                <DataGridTextColumn Header="Alter" Binding="{Binding Alter}" SortMemberPath="Alter" Width="80" IsReadOnly="True"/>
                <DataGridTextColumn Header="E-Mail" Binding="{Binding Email}" SortMemberPath="Email" Width="2*" IsReadOnly="True"/>
                <DataGridTextColumn Header="Telefon" Binding="{Binding Telefonnummer}" SortMemberPath="Telefonnummer" Width="160" IsReadOnly="True"/>

                <DataGridTemplateColumn Header="Aktiv" Width="70" SortMemberPath="IsActive">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsActive, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Checked="ActiveCheckBox_Changed"
                                      Unchecked="ActiveCheckBox_Changed"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Status" Width="110" SortMemberPath="IsActive">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock FontWeight="SemiBold" HorizontalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Inaktiv"/>
                                        <Setter Property="Foreground" Value="Red"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                <Setter Property="Text" Value="Aktiv"/>
                                                <Setter Property="Foreground" Value="Green"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="Zurück"
                    Width="100"
                    Height="28"
                    Margin="0,0,10,0"
                    Click="PrevPage_Click"/>

            <TextBlock x:Name="PageInfoText"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"/>

            <Button Content="Weiter"
                    Width="100"
                    Height="28"
                    Click="NextPage_Click"/>
        </StackPanel>

        <TextBlock Grid.Row="3"
                   x:Name="StatusText"
                   Margin="0,10,0,0"
                   Foreground="Gray"/>
    </Grid>
</Window>