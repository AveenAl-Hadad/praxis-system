<Window x:Class="Praxis.Client.Views.NoticeEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hinweis"
        Height="420"
        Width="540"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="130"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0"
                   Text="Titel:"
                   VerticalAlignment="Center"
                   Margin="0,0,10,0"/>
        <TextBox Grid.Row="0" Grid.Column="1"
                 x:Name="TitleTextBox"
                 MinWidth="260"/>

        <TextBlock Grid.Row="2" Grid.Column="0"
                   Text="Hinweis:"
                   VerticalAlignment="Top"
                   Margin="0,4,10,0"/>
        <TextBox Grid.Row="2" Grid.Column="1"
                 x:Name="ContentTextBox"
                 Height="100"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"/>

        <TextBlock Grid.Row="4" Grid.Column="0"
                   Text="Kategorie:"
                   VerticalAlignment="Center"
                   Margin="0,0,10,0"/>
        <ComboBox Grid.Row="4" Grid.Column="1"
                  x:Name="CategoryComboBox"
                  SelectedIndex="0">
            <ComboBoxItem Content="Info"/>
            <ComboBoxItem Content="Wichtig"/>
            <ComboBoxItem Content="Warnung"/>
        </ComboBox>

        <TextBlock Grid.Row="6" Grid.Column="0"
                   Text="Sichtbar bis:"
                   VerticalAlignment="Center"
                   Margin="0,0,10,0"/>
        <DatePicker Grid.Row="6" Grid.Column="1"
                    x:Name="VisibleUntilPicker"/>

        <CheckBox Grid.Row="8" Grid.Column="1"
                  x:Name="PinnedCheckBox"
                  Content="Hinweis anheften"/>

        <StackPanel Grid.Row="10" Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Speichern"
                    Width="110"
                    Margin="0,0,10,0"
                    Click="SaveButton_Click"/>
            <Button Content="Abbrechen"
                    Width="110"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>